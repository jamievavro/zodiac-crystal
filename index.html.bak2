<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Zodiac Crystal Guide</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:Georgia,serif;background:#fdf8f0;color:#3a2a10;min-height:100vh;}
.app-header{background:linear-gradient(135deg,#2d1b4e,#5a3080);color:white;text-align:center;padding:28px 20px 22px;position:relative;overflow:hidden;}
.app-header::before{content:'\2726 \2727 \2726 \2727 \2726 \2727 \2726 \2727 \2726 \2727';position:absolute;top:8px;left:0;right:0;text-align:center;font-size:.7rem;opacity:.4;letter-spacing:6px;}
.app-header::after{content:'\2726 \2727 \2726 \2727 \2726 \2727 \2726 \2727 \2726 \2727';position:absolute;bottom:8px;left:0;right:0;text-align:center;font-size:.7rem;opacity:.4;letter-spacing:6px;}
.app-header h1{font-size:clamp(1.5rem,4vw,2.2rem);letter-spacing:.1em;text-transform:uppercase;font-weight:normal;}
.app-header p{font-size:.82rem;opacity:.7;margin-top:5px;letter-spacing:.12em;text-transform:uppercase;}
.nav-tabs{display:flex;background:#1e0e38;border-bottom:1px solid rgba(255,255,255,.1);overflow-x:auto;}
.nav-tabs::-webkit-scrollbar{display:none;}
.nav-tab{flex:1;padding:13px 10px;border:none;background:none;color:rgba(255,255,255,.55);font-family:Georgia,serif;font-size:.82rem;cursor:pointer;white-space:nowrap;letter-spacing:.05em;border-bottom:3px solid transparent;transition:all .22s;}
.nav-tab:hover{color:rgba(255,255,255,.85);background:rgba(255,255,255,.05);}
.nav-tab.on{color:white;border-bottom-color:#c084fc;background:rgba(192,132,252,.1);}
.page{display:none;}.page.on{display:block;}
.guide{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:16px;max-width:1200px;margin:0 auto;padding:20px;}
.zcard{background:white;border:1.5px solid #e8dcc8;border-radius:12px;overflow:hidden;box-shadow:0 2px 12px rgba(100,60,20,.1);transition:transform .25s,box-shadow .25s;cursor:pointer;}
.zcard:hover{transform:translateY(-4px);box-shadow:0 8px 24px rgba(100,60,20,.18);}
.zsign-header{padding:11px 16px 10px;display:flex;align-items:center;gap:10px;border-bottom:1px solid #f0e8d8;}
.zsign-name{font-size:1.05rem;font-weight:bold;letter-spacing:.12em;text-transform:uppercase;}
.zsign-dates{font-size:.7rem;color:rgba(255,255,255,.8);letter-spacing:.06em;}
.crystal-row{display:flex;align-items:center;justify-content:space-around;padding:14px 12px 12px;background:#fffef8;border-bottom:1px solid #f0e8d8;gap:6px;}
.crystal-item{display:flex;flex-direction:column;align-items:center;gap:6px;flex:1;}
.crystal-photo{width:80px;height:80px;border-radius:50%;overflow:hidden;border:2px solid #e8dcc8;background:#f5efe0;display:flex;align-items:center;justify-content:center;box-shadow:0 3px 10px rgba(0,0,0,.15);}
.crystal-photo img{width:100%;height:100%;object-fit:cover;display:block;}
.crystal-name{font-size:.6rem;color:#5a4060;text-align:center;font-weight:bold;letter-spacing:.04em;line-height:1.3;max-width:80px;}
.zcard-body{padding:12px 16px 14px;}
.zcard-desc{font-size:.8rem;line-height:1.65;color:#6a5040;margin-bottom:9px;}
.zcard-traits{display:flex;gap:5px;flex-wrap:wrap;}
.ztrait{padding:3px 9px;border-radius:20px;font-size:.68rem;font-weight:bold;background:#f0e8f8;color:#7a5090;border:1px solid #ddd0f0;}
.overlay{position:fixed;inset:0;background:rgba(30,10,60,.5);backdrop-filter:blur(8px);z-index:500;display:none;align-items:center;justify-content:center;padding:14px;}
.overlay.on{display:flex;}
.modal{background:white;border-radius:20px;max-width:560px;width:100%;max-height:92vh;overflow-y:auto;box-shadow:0 24px 60px rgba(30,10,60,.3);}
.modal::-webkit-scrollbar{display:none;}
.modal-banner{padding:22px 20px 18px;text-align:center;position:relative;}
.modal-title{font-size:1.8rem;font-weight:bold;letter-spacing:.1em;text-transform:uppercase;margin-top:4px;}
.modal-dates{font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;margin-top:2px;opacity:.75;}
.xbtn{position:absolute;top:16px;right:16px;width:32px;height:32px;border-radius:50%;border:none;background:rgba(255,255,255,.3);color:white;font-size:1rem;cursor:pointer;}
.modal-body{padding:20px 22px 28px;}
.modal-crystals{display:flex;gap:12px;margin-bottom:20px;flex-wrap:wrap;justify-content:center;}
.modal-crystal{display:flex;flex-direction:column;align-items:center;gap:8px;flex:1;min-width:120px;max-width:160px;}
.modal-crystal-photo{width:100px;height:100px;border-radius:50%;overflow:hidden;border:3px solid #e8dcc8;background:#f5efe0;box-shadow:0 4px 16px rgba(0,0,0,.15);}
.modal-crystal-photo img{width:100%;height:100%;object-fit:cover;display:block;}
.modal-crystal-name{font-size:.85rem;font-weight:bold;color:#3a2a10;text-align:center;}
.modal-crystal-power{font-size:.72rem;color:#9080a0;text-align:center;letter-spacing:.06em;text-transform:uppercase;}
.modal-crystal-desc{font-size:.78rem;color:#6a5040;text-align:center;line-height:1.55;}
.mtabs{display:flex;border-bottom:2px solid #f0e8d8;margin-bottom:16px;}
.mtab{flex:1;padding:9px 6px;border:none;background:none;font-family:Georgia,serif;font-size:.8rem;color:#9080a0;cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;}
.mtab.on{color:#7a5090;border-bottom-color:#7a5090;font-weight:bold;}
.mpanel{display:none;}.mpanel.on{display:block;}
.hcard{background:linear-gradient(135deg,#fdf0f8,#f0e8f8);border:1.5px solid #ddd0f0;border-radius:12px;padding:16px;margin-bottom:12px;}
.hdate{font-size:.68rem;font-weight:bold;letter-spacing:.12em;text-transform:uppercase;color:#7a5090;margin-bottom:7px;}
.htext{font-size:.87rem;line-height:1.78;color:#3a2a10;}
.hscores{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:11px;}
.hscore{background:white;border-radius:10px;padding:9px 12px;border:1.5px solid #e8dcc8;}
.hslbl{font-size:.65rem;font-weight:bold;letter-spacing:.1em;text-transform:uppercase;color:#9080a0;margin-bottom:4px;}
.hsbar{height:5px;background:#f0e8d8;border-radius:10px;overflow:hidden;}
.hsfill{height:100%;border-radius:10px;}
.hsval{font-size:.7rem;font-weight:bold;color:#7a5090;margin-top:3px;}
.hlucky{display:flex;gap:7px;flex-wrap:wrap;margin-top:11px;}
.lchip{background:white;border:1.5px solid #e8dcc8;border-radius:10px;padding:7px 11px;}
.lclbl{font-size:.6rem;font-weight:bold;letter-spacing:.1em;text-transform:uppercase;color:#9080a0;}
.lcval{font-size:.8rem;font-weight:bold;color:#3a2a10;}
.hinsight{background:#fafaf5;border-radius:10px;padding:9px 13px;margin-bottom:7px;border:1.5px solid #ece8d8;}
.hilbl{font-size:.63rem;font-weight:bold;letter-spacing:.1em;text-transform:uppercase;color:#9080a0;margin-bottom:2px;}
.hitxt{font-size:.82rem;line-height:1.65;color:#3a2a10;}
.affbox{background:linear-gradient(135deg,#fdf0f8,#f0e8f8);border:1.5px solid #ddd0f0;border-radius:12px;padding:14px 16px;font-style:italic;font-size:.9rem;color:#7a5090;text-align:center;line-height:1.6;}
.spin{width:28px;height:28px;border:3px solid #f0e8d8;border-top-color:#7a5090;border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 10px;}
.hload{text-align:center;padding:30px 20px;color:#9080a0;}
.herr{background:#fdf0f0;border:1.5px solid #f0c8c8;border-radius:12px;padding:14px;font-size:.82rem;color:#7a3030;text-align:center;}
.retrybtn{padding:7px 16px;border-radius:20px;border:none;background:#e8d0f0;color:#5a3080;font-weight:bold;cursor:pointer;font-family:Georgia,serif;margin-top:9px;}
.el-fire{background:linear-gradient(135deg,#c0392b,#e74c3c);}
.el-earth{background:linear-gradient(135deg,#27ae60,#2ecc71);}
.el-air{background:linear-gradient(135deg,#2980b9,#3498db);}
.el-water{background:linear-gradient(135deg,#5a3080,#9b7cc8);}
@keyframes spin{to{transform:rotate(360deg);}}
/* ── GEMINI KEY PROMPT ───────────────────────────────────── */
#gemini-key-input:focus{border-color:#a78bfa!important;box-shadow:0 0 0 2px rgba(167,139,250,.25);}
#gemini-key-input::placeholder{color:#6050a0;}

/* ── CRYSTAL BODY PLACEMENT DIAGRAM ─────────────────────── */
.body-diagram-wrap{background:rgba(0,0,0,.3);border:1.5px solid rgba(168,230,192,.2);border-radius:18px;padding:18px;margin-bottom:16px;}
.body-diagram-title{font-size:.72rem;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:#a8e6c0;margin-bottom:6px;display:flex;align-items:center;gap:7px;}
.body-diagram-subtitle{font-size:.8rem;color:rgba(168,230,192,.65);margin-bottom:14px;line-height:1.55;}
.body-diagram-svg-wrap{border-radius:14px;overflow:hidden;max-width:360px;margin:0 auto;}
.body-diagram-steps{margin-top:14px;}
.body-step{display:flex;gap:10px;align-items:flex-start;padding:8px 0;border-bottom:1px solid rgba(168,230,192,.1);font-size:.82rem;color:#c8e8d8;line-height:1.5;}
.body-step:last-child{border-bottom:none;}
.body-step-num{width:22px;height:22px;border-radius:50%;background:rgba(168,230,192,.18);border:1px solid rgba(168,230,192,.35);display:flex;align-items:center;justify-content:center;font-size:.68rem;font-weight:800;color:#a8e6c0;flex-shrink:0;margin-top:1px;}
.crystal-legend{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px;}
.crystal-legend-item{display:flex;align-items:center;gap:5px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:4px 10px;}
.crystal-legend-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
.crystal-legend-text{font-size:.72rem;color:#c8e8d8;}


/* ── YOGA POSE CARDS ──────────────────────────────────────────── */
.yoga-pose-card{background:rgba(255,255,255,.05);border:1.5px solid rgba(168,200,230,.2);border-radius:16px;overflow:hidden;margin-bottom:14px;cursor:pointer;transition:transform .2s,box-shadow .2s;}
.yoga-pose-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.3);}
.yoga-pose-header{display:flex;align-items:stretch;gap:0;}
.yoga-pose-art{width:100px;min-width:100px;background:rgba(0,0,0,.2);display:flex;align-items:center;justify-content:center;padding:8px;}
.yoga-pose-art svg{width:84px;height:112px;border-radius:8px;}
.yoga-pose-meta{flex:1;padding:13px 14px;}
.yoga-pose-name{font-family:Georgia,serif;font-size:1rem;font-weight:bold;color:#e8f8f0;margin-bottom:2px;}
.yoga-pose-sanskrit{font-size:.7rem;color:#7ab89a;font-style:italic;margin-bottom:8px;letter-spacing:.06em;}
.yoga-pose-duration{display:inline-block;font-size:.66rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;background:rgba(168,230,192,.15);color:#a8e6c0;border:1px solid rgba(168,230,192,.25);border-radius:20px;padding:3px 9px;margin-bottom:7px;}
.yoga-pose-benefits{font-size:.78rem;line-height:1.6;color:#c8e8d8;}
.yoga-pose-steps{max-height:0;overflow:hidden;transition:max-height .4s ease;}
.yoga-pose-card.expanded .yoga-pose-steps{max-height:400px;}
.yoga-steps-inner{padding:12px 14px 14px;border-top:1px solid rgba(168,230,192,.15);}
.yoga-steps-title{font-size:.68rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:#a8e6c0;margin-bottom:9px;}
.yoga-step{display:flex;gap:9px;align-items:flex-start;margin-bottom:7px;font-size:.8rem;line-height:1.55;color:#c8e8d8;}
.yoga-step-num{width:20px;height:20px;border-radius:50%;background:rgba(168,230,192,.2);border:1px solid rgba(168,230,192,.4);display:flex;align-items:center;justify-content:center;font-size:.65rem;font-weight:800;color:#a8e6c0;flex-shrink:0;margin-top:1px;}
.yoga-expand-hint{font-size:.68rem;color:#7ab89a;text-align:center;padding:5px 0 8px;letter-spacing:.08em;}


/* ── HEALING PAGE ─────────────────────────────────────── */
#healing-page{background:linear-gradient(180deg,#0a1a10 0%,#0a1520 100%);min-height:calc(100vh - 110px);padding-bottom:60px;}
.healing-hero{text-align:center;padding:32px 20px 18px;}
.healing-hero h2{font-size:clamp(1.5rem,4vw,2rem);color:#a8e6c0;font-family:Georgia,serif;font-style:italic;margin-bottom:6px;}
.healing-hero p{font-size:.83rem;color:#7ab89a;letter-spacing:.08em;}
.sign-picker{display:flex;justify-content:center;gap:7px;flex-wrap:wrap;padding:0 16px 22px;}
.sign-pick-btn{background:rgba(255,255,255,.06);border:1.5px solid rgba(168,230,192,.25);color:#a8e6c0;font-family:Georgia,serif;font-size:.78rem;padding:7px 13px;border-radius:50px;cursor:pointer;transition:all .22s;}
.sign-pick-btn:hover,.sign-pick-btn.on{background:rgba(168,230,192,.2);border-color:#a8e6c0;color:#e8f8f0;}
.healing-panel{max-width:680px;margin:0 auto;padding:0 16px;}
.healing-sign-hdr{display:flex;align-items:center;gap:12px;margin-bottom:18px;padding-bottom:14px;border-bottom:1px solid rgba(168,230,192,.2);}
.healing-sign-em{font-size:2.5rem;}
.healing-sign-name{font-family:Georgia,serif;font-size:1.5rem;color:#a8e6c0;}
.healing-sign-el{font-size:.68rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:#7ab89a;margin-top:2px;}
.h-card{background:rgba(255,255,255,.05);border:1.5px solid rgba(168,230,192,.18);border-radius:16px;padding:18px 20px;margin-bottom:14px;}
.h-card-title{font-size:.7rem;font-weight:800;letter-spacing:.14em;text-transform:uppercase;margin-bottom:10px;display:flex;align-items:center;gap:7px;}
.h-card-title .ico{width:26px;height:26px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0;}
.h-text{font-size:.85rem;line-height:1.82;color:#c8e8d8;}
.crys-pills{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;}
.crys-pill{display:flex;align-items:center;gap:7px;background:rgba(168,230,192,.1);border:1px solid rgba(168,230,192,.25);border-radius:50px;padding:5px 12px 5px 5px;}
.crys-pill-img{width:30px;height:30px;border-radius:50%;overflow:hidden;border:1.5px solid rgba(168,230,192,.4);background:#1a2a1a;flex-shrink:0;}
.crys-pill-img img{width:100%;height:100%;object-fit:cover;display:block;}
.crys-pill-name{font-size:.74rem;font-weight:700;color:#a8e6c0;}
.yoga-item{background:rgba(255,255,255,.04);border-radius:12px;padding:12px 14px;margin-bottom:8px;border-left:3px solid #7ab8d8;}
.yoga-item-pose{font-size:.88rem;font-weight:700;color:#b8d8f8;margin-bottom:3px;}
.yoga-item-desc{font-size:.79rem;color:#8ab8c8;line-height:1.6;}
.h-affirmation{background:linear-gradient(135deg,rgba(20,60,30,.5),rgba(10,40,50,.5));border:1.5px solid rgba(168,230,192,.3);border-radius:14px;padding:16px;text-align:center;font-style:italic;color:#a8e6c0;font-size:.92rem;line-height:1.65;margin-top:6px;}
/* ── CRYSTAL MEANINGS IN MODAL ──────────────────────────── */
.meaning-intro{font-size:.82rem;color:#9080a0;line-height:1.65;margin-bottom:14px;padding:10px 12px;background:#fdf5ff;border-radius:12px;border-left:3px solid #d8c6f0;font-style:italic;}
.meaning-card{display:flex;gap:13px;align-items:flex-start;background:white;border-radius:14px;border:1.5px solid #ede5f8;padding:13px;margin-bottom:12px;box-shadow:0 2px 8px rgba(155,124,200,.1);}
.meaning-photo{width:76px;height:76px;border-radius:50%;overflow:hidden;border:2.5px solid #e8dcc8;background:#f5efe0;flex-shrink:0;display:flex;align-items:center;justify-content:center;}
.meaning-photo img{width:100%;height:100%;object-fit:cover;display:block;}
.meaning-body{flex:1;min-width:0;}
.meaning-name{font-family:Georgia,serif;font-size:1rem;color:#3a2a10;font-weight:bold;margin-bottom:2px;}
.meaning-power{font-size:.67rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:#9b7cc8;margin-bottom:7px;}
.meaning-text{font-size:.81rem;line-height:1.72;color:#6a5040;}

#tarot-page{background:linear-gradient(180deg,#120828 0%,#1e0e38 100%);min-height:calc(100vh - 110px);padding-bottom:60px;}
.tarot-hero{text-align:center;padding:36px 20px 24px;}
.tarot-hero h2{font-size:clamp(1.6rem,4vw,2.2rem);color:#e9d5ff;letter-spacing:.08em;font-style:italic;margin-bottom:6px;}
.tarot-hero p{font-size:.88rem;color:#a78bfa;letter-spacing:.1em;}
.spread-selector{display:flex;justify-content:center;gap:10px;flex-wrap:wrap;padding:0 20px 28px;}
.spread-btn{background:transparent;border:1.5px solid rgba(192,132,252,.5);color:#c084fc;font-family:Georgia,serif;font-size:.83rem;padding:11px 20px;border-radius:50px;cursor:pointer;letter-spacing:.06em;transition:all .25s;}
.spread-btn:hover,.spread-btn.on{background:rgba(192,132,252,.18);border-color:#c084fc;color:#e9d5ff;}
.ppf-tab{background:transparent;border:1.5px solid rgba(192,132,252,.35);color:#a78bfa;font-family:Georgia,serif;font-size:.78rem;padding:8px 18px;border-radius:50px;cursor:pointer;letter-spacing:.06em;transition:all .22s;}
.ppf-tab:hover,.ppf-tab.on{background:rgba(192,132,252,.2);border-color:#c084fc;color:#e9d5ff;}
.ppf-tab.ppf-all{border-color:rgba(251,191,36,.4);color:#fbbf24;}
.ppf-tab.ppf-all:hover,.ppf-tab.ppf-all.on{background:rgba(251,191,36,.15);border-color:#fbbf24;color:#fef3c7;}
.ppf-panel{display:none;}.ppf-panel.on{display:block;}
.tarot-question-wrap{max-width:500px;margin:0 auto 28px;padding:0 20px;}
.tarot-question{width:100%;background:rgba(255,255,255,.06);border:1.5px solid rgba(192,132,252,.3);border-radius:14px;padding:14px 16px;color:#e9d5ff;font-family:Georgia,serif;font-size:.9rem;resize:none;outline:none;line-height:1.55;}
.tarot-question::placeholder{color:rgba(192,132,252,.5);}
.tarot-question:focus{border-color:#c084fc;}
.draw-wrap{text-align:center;margin-bottom:36px;}
.draw-btn{background:linear-gradient(135deg,#7c3aed,#a855f7);color:white;border:none;padding:15px 40px;border-radius:50px;font-family:Georgia,serif;font-size:1rem;letter-spacing:.1em;cursor:pointer;box-shadow:0 4px 20px rgba(124,58,237,.4);transition:all .3s;}
.draw-btn:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(124,58,237,.5);}
.draw-btn:disabled{opacity:.5;cursor:not-allowed;transform:none;}
.tarot-cards-area{min-height:260px;display:flex;justify-content:center;align-items:flex-start;flex-wrap:wrap;gap:18px;padding:0 20px 8px;}
.tarot-card-wrap{display:flex;flex-direction:column;align-items:center;gap:10px;}
.tarot-pos-label{font-size:.68rem;font-weight:bold;letter-spacing:.14em;text-transform:uppercase;color:#a78bfa;}
.tarot-card{width:110px;height:185px;border-radius:10px;position:relative;cursor:pointer;perspective:1000px;}
.tarot-card-inner{width:100%;height:100%;position:relative;transform-style:preserve-3d;transition:transform .7s cubic-bezier(.4,0,.2,1);border-radius:10px;}
.tarot-card.flipped .tarot-card-inner{transform:rotateY(180deg);}
.tarot-card-back,.tarot-card-front{position:absolute;inset:0;border-radius:10px;backface-visibility:hidden;-webkit-backface-visibility:hidden;overflow:hidden;box-shadow:0 6px 24px rgba(0,0,0,.5);}
.tarot-card-back{background:linear-gradient(135deg,#1e0e38,#2d1b4e);border:2px solid rgba(192,132,252,.4);display:flex;align-items:center;justify-content:center;font-size:2.2rem;}
.tarot-card-back::before{content:'';position:absolute;inset:8px;border:1px solid rgba(192,132,252,.25);border-radius:6px;}
.tarot-card-front{transform:rotateY(180deg);display:flex;flex-direction:column;border:2px solid rgba(255,255,255,.15);}
.card-art{flex:1;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;}
.card-art svg{width:100%;height:100%;display:block;}
.card-numeral{position:absolute;top:6px;left:0;right:0;text-align:center;font-size:.6rem;font-weight:bold;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.7);}
.card-reversed-badge{position:absolute;bottom:4px;right:5px;font-size:.48rem;font-weight:bold;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,150,150,.85);background:rgba(0,0,0,.4);padding:1px 4px;border-radius:4px;}
.card-footer{padding:7px 5px 8px;text-align:center;background:rgba(0,0,0,.4);}
.card-name-small{font-size:.6rem;font-weight:bold;letter-spacing:.06em;color:#e9d5ff;line-height:1.2;}
.reading-result{max-width:660px;margin:28px auto 0;padding:0 20px;}
.reading-loading{text-align:center;padding:40px 20px;color:#a78bfa;}
.read-spin{width:36px;height:36px;border:3px solid rgba(192,132,252,.3);border-top-color:#c084fc;border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 14px;}
.reading-card{background:rgba(255,255,255,.05);border:1.5px solid rgba(192,132,252,.25);border-radius:18px;padding:22px 24px;margin-bottom:16px;}
.reading-title{font-size:1.1rem;color:#e9d5ff;margin-bottom:6px;letter-spacing:.05em;}
.reading-spread-name{font-size:.7rem;color:#a78bfa;letter-spacing:.14em;text-transform:uppercase;margin-bottom:16px;}
.reading-divider{height:1px;background:linear-gradient(90deg,transparent,rgba(192,132,252,.4),transparent);margin:14px 0;}
.reading-section{margin-bottom:14px;}
.reading-section-title{font-size:.7rem;font-weight:bold;letter-spacing:.14em;text-transform:uppercase;color:#c084fc;margin-bottom:6px;}
.reading-text{font-size:.88rem;line-height:1.82;color:#e9d5ff;}
.card-summary-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px;}
.card-pill{background:rgba(192,132,252,.15);border:1px solid rgba(192,132,252,.3);border-radius:20px;padding:5px 12px;font-size:.72rem;color:#e9d5ff;}
.card-pill span{color:#c084fc;font-weight:bold;}
.reading-affirmation{background:linear-gradient(135deg,rgba(124,58,237,.2),rgba(168,85,247,.2));border:1.5px solid rgba(192,132,252,.35);border-radius:14px;padding:16px;text-align:center;font-style:italic;color:#c084fc;font-size:.92rem;line-height:1.65;}
.new-reading-btn{display:block;width:fit-content;margin:20px auto 0;background:transparent;border:1.5px solid rgba(192,132,252,.5);color:#c084fc;font-family:Georgia,serif;font-size:.85rem;padding:10px 24px;border-radius:50px;cursor:pointer;letter-spacing:.06em;transition:all .25s;}
.new-reading-btn:hover{background:rgba(192,132,252,.15);}
.reading-err{background:rgba(255,100,100,.1);border:1.5px solid rgba(255,100,100,.3);border-radius:14px;padding:16px;text-align:center;color:#fca5a5;font-size:.85rem;}
@media(max-width:480px){.guide{grid-template-columns:1fr;padding:12px;}.crystal-photo{width:64px;height:64px;}.modal-crystal-photo{width:80px;height:80px;}.hscores{grid-template-columns:1fr;}}
</style>
</head>
<body>
<div class="app-header">
  <h1>&#10024; Zodiac Crystal Guide</h1>
  <p>12 Signs &#8226; 36 Healing Crystals &#8226; Tarot Readings</p>
</div>
<div style="position:absolute;top:12px;right:14px;z-index:100">
  <button onclick="promptForKey(function(){})" title="Change Gemini API Key"
    style="background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);border-radius:50%;width:32px;height:32px;cursor:pointer;font-size:14px;color:white;display:flex;align-items:center;justify-content:center">
    &#9881;&#65039;
  </button>
</div>
<div class="nav-tabs">
  <button class="nav-tab on" onclick="showPage('zodiac',this)">&#127775; Zodiac Signs</button>
  <button class="nav-tab" onclick="showPage('healing',this)">&#129544; Crystal Healing</button>
  <button class="nav-tab" onclick="showPage('tarot',this)">&#127183; Tarot Reading</button>
</div>
<div class="page on" id="zodiac-page">
  <div class="guide" id="guide"></div>
</div>
<div class="page" id="healing-page">
  <div id="healing-content"></div>
</div>

<div class="page" id="tarot-page">
  <div class="tarot-hero">
    <h2>&#9997;&#65039; Your Tarot Reading</h2>
    <p>Ask a question &#8226; Choose a spread &#8226; Reveal your cards</p>
  </div>

  <!-- What is Tarot explanation -->
  <div style="max-width:680px;margin:0 auto 24px;padding:0 18px;">
    <div style="background:linear-gradient(135deg,rgba(124,92,191,.18),rgba(74,42,143,.22));border:1.5px solid rgba(167,139,250,.3);border-radius:18px;padding:20px 22px;">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
        <span style="font-size:1.6rem;">&#127183;</span>
        <div style="font-family:Georgia,serif;font-size:1.05rem;color:#d4b8ff;font-weight:bold;">What is Tarot?</div>
      </div>
      <p style="font-size:.85rem;color:#c4b0e8;line-height:1.8;margin-bottom:12px;">Tarot is an ancient practice using a deck of 78 cards — each one filled with symbols, archetypes, and wisdom — to help you reflect on your life, relationships, and path forward. Tarot does not predict the future. Instead it acts as a mirror, helping you see your situation more clearly and trust your own intuition.</p>
      <p style="font-size:.85rem;color:#c4b0e8;line-height:1.8;margin-bottom:16px;">Each card carries a unique meaning and energy. When you draw cards, they reflect the energy surrounding you right now — inviting you to pause, reflect, and listen to your inner wisdom.</p>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;">
        <div style="background:rgba(255,255,255,.06);border-radius:12px;padding:12px;">
          <div style="font-size:1rem;margin-bottom:4px;">&#10024;</div>
          <div style="font-size:.78rem;font-weight:700;color:#e9d5ff;margin-bottom:4px;">Daily Card</div>
          <div style="font-size:.75rem;color:#a78bcc;line-height:1.6;">One card for guidance, reflection, or a theme to carry through your day.</div>
        </div>
        <div style="background:rgba(255,255,255,.06);border-radius:12px;padding:12px;">
          <div style="font-size:1rem;margin-bottom:4px;">&#10084;&#65039;</div>
          <div style="font-size:.78rem;font-weight:700;color:#e9d5ff;margin-bottom:4px;">Love Reading</div>
          <div style="font-size:.75rem;color:#a78bcc;line-height:1.6;">Five cards exploring your heart, their heart, your connection, what to release, and what can bloom.</div>
        </div>
        <div style="background:rgba(255,255,255,.06);border-radius:12px;padding:12px;">
          <div style="font-size:1rem;margin-bottom:4px;">&#9755;</div>
          <div style="font-size:.78rem;font-weight:700;color:#e9d5ff;margin-bottom:4px;">Past · Present · Future</div>
          <div style="font-size:.75rem;color:#a78bcc;line-height:1.6;">Three cards showing where you have been, where you are, and where you are headed.</div>
        </div>
        <div style="background:rgba(255,255,255,.06);border-radius:12px;padding:12px;">
          <div style="font-size:1rem;margin-bottom:4px;">&#9775;</div>
          <div style="font-size:.78rem;font-weight:700;color:#e9d5ff;margin-bottom:4px;">Celtic Cross</div>
          <div style="font-size:.75rem;color:#a78bcc;line-height:1.6;">Ten cards for a deep, detailed reading covering all areas of your situation and outcome.</div>
        </div>
      </div>
      <div style="background:rgba(167,139,250,.12);border-radius:10px;padding:10px 14px;font-size:.78rem;color:#c4b0e8;line-height:1.65;font-style:italic;">
        &#128161; <strong style="color:#e9d5ff;">How to use:</strong> Take a breath, think of a question or situation in your life, choose a spread below, then tap "Draw My Cards." Your AI reader will interpret your cards with wisdom and compassion.
      </div>
    </div>
  </div>

  <div class="spread-selector">
    <button class="spread-btn on" onclick="selectSpread('single',this)">&#10024; Daily Card</button>
    <button class="spread-btn" onclick="selectSpread('love',this)">&#10084;&#65039; Love Reading</button>
    <button class="spread-btn" onclick="selectSpread('three',this)">&#9755; Past &#8226; Present &#8226; Future</button>
    <button class="spread-btn" onclick="selectSpread('celtic',this)">&#9775; Celtic Cross</button>
  </div>
  <div id="ppf-tabs" style="display:none;justify-content:center;gap:8px;padding:0 20px 18px;flex-wrap:wrap;">
    <button class="ppf-tab on" id="ppf-all" onclick="switchPPFpanel(-1,this)">All Three &#9775;</button>
    <button class="ppf-tab" id="ppf-0" onclick="switchPPFpanel(0,this)">&#8592; Past</button>
    <button class="ppf-tab" id="ppf-1" onclick="switchPPFpanel(1,this)">&#9678; Present</button>
    <button class="ppf-tab" id="ppf-2" onclick="switchPPFpanel(2,this)">Future &#8594;</button>
  </div>
  <div id="love-header" style="display:none;text-align:center;padding:0 20px 16px;">
    <div style="font-size:2rem;margin-bottom:6px">&#10084;&#65039; &#128149; &#10084;&#65039;</div>
    <p style="color:#f9a8d4;font-size:.85rem;letter-spacing:.08em;font-style:italic;">A five-card spread revealing the truth of your heart</p>
  </div>
  <div class="tarot-question-wrap">
    <textarea class="tarot-question" id="tarot-question" rows="2" placeholder="Ask the cards a question... (optional)"></textarea>
  </div>
  <div class="draw-wrap">
    <button class="draw-btn" id="draw-btn" onclick="drawCards()">&#10024; Draw My Cards</button>
  </div>
  <div class="tarot-cards-area" id="cards-area"></div>
  <div class="reading-result" id="reading-result"></div>
</div>
<div class="overlay" id="overlay" onclick="maybeClose(event)">
  <div class="modal" id="modal"></div>
</div>
<script>

// ── WELLNESS DATA ─────────────────────────────────────────────────────────────
var WELLNESS={
"Aries":{placement:"Place Carnelian on your sacral chakra (2 inches below navel) during meditation to ignite confidence. Keep Amethyst on your nightstand to calm the mind before sleep. Carry Rose Quartz in your left pocket to stay heart-open throughout the day.",healing:"Hold Carnelian during breathwork to release anger stored in the body. Grid all three stones around your yoga mat before practice. Drink Amethyst-charged water (place stone beside a glass overnight) to ease stress headaches common to Aries.",balance:"Your fiery nature burns bright but burns fast. Build in one non-negotiable daily rest: 10 minutes lying down with Amethyst on your forehead. Channel your competitive drive into nature walks or solo exercise. Cook a slow meal once a week - the patience required is medicine for Aries.",yoga:["Warrior I - channels Aries courage into grounded power","Camel Pose - opens the heart and softens the warrior","Child Pose - the ultimate Aries surrender, releases head tension","Headstand - feeds Aries love of challenge while calming the nervous system","Lion Breath - releases frustration and Aries pent-up energy"],affirmation:"I channel my fire with wisdom. I rest as fiercely as I act."},
"Taurus":{placement:"Place Malachite on your heart during meditation to open yourself to change. Set Citrine in the wealth corner of your home (far left from the front door) to attract abundance. Keep Rose Quartz beside your bed to enhance self-love rituals.",healing:"Lie down and place Rose Quartz on your heart, Malachite on your solar plexus, and Citrine in each hand. Breathe slowly for 20 minutes - this trio releases emotional blocks Taurus holds in the body. Take crystal baths with Rose Quartz beside the tub.",balance:"Taurus can get stuck in comfort zones that become cages. Schedule one new experience monthly - a new recipe, trail, or class. Ground yourself daily with bare feet on earth. Prioritize sleep, nourishing food, and sensual pleasure without guilt.",yoga:["Mountain Pose - Taurus embodied: stable, rooted, present","Tree Pose - strengthens natural groundedness","Seated Forward Fold - releases stubbornness held in hamstrings","Goddess Pose - awakens Taurus sensual earthy power","Savasana - Taurus reward: total guilt-free rest"],affirmation:"I am rooted in abundance. I welcome change as part of my growth."},
"Gemini":{placement:"Keep Moonstone on your writing desk to bring intuitive balance to your busy mind. Carry Labradorite daily for aura protection. Place Black Onyx in your workspace to maintain focus during long tasks.",healing:"Hold one crystal in each hand during meditation: Moonstone left, Black Onyx right. Breathe for 5 counts in, 5 out - this balances Gemini dual nature. When anxious, hold Labradorite and trace its iridescent flash as a mindfulness anchor.",balance:"Your mind is your greatest gift and your greatest stress source. Institute a true digital-free hour each evening. Journal daily to process the constant stream of thoughts. Spend time with one person in deep conversation rather than many people at surface level.",yoga:["Eagle Pose - requires total concentration, quiets the chattering Gemini mind","Seated Spinal Twist - supports Gemini lungs and nervous system","Alternate Nostril Breathing - balances both sides of the Gemini brain","Butterfly Pose - opens communication channels and releases shoulder tension","Wide-Legged Forward Fold - grounds scattered air energy"],affirmation:"I focus my brilliant mind. One breath, one moment, one truth at a time."},
"Cancer":{placement:"Place Moonstone on your third eye during meditation for deep intuitive downloads. Keep Selenite near your front door to cleanse energy entering your home. Sleep with Black Obsidian under your pillow only when you feel emotionally strong.",healing:"Create a crystal sanctuary in one corner of your bedroom: Selenite wand to cleanse, Moonstone for emotional wisdom, Black Obsidian for protection. Lie in this space when overwhelmed and breathe until your nervous system settles.",balance:"You give so generously that you often forget to receive. Practice the radical act of asking for help once a week. Create a home ritual entirely for you - a tea ceremony, a bath, a journaling session. Protect your energy by limiting time with draining people.",yoga:["Supported Fish Pose - opens Cancer protected chest and heart","Moon Salutation - aligns Cancer with their lunar ruler","Hip Circles in Cat-Cow - releases grief and emotion stored in hips","Legs Up the Wall - the great Cancer nervous system reset","Yin Yoga Hip Openers - creates safe space for deep emotional release"],affirmation:"I am safe to feel. I release what is not mine and nourish what is."},
"Leo":{placement:"Place Pyrite on your work desk to amplify confidence and attract success energy. Wear or carry Tiger Eye for focus and power throughout the day. Keep Rose Quartz near your heart - on a necklace or in your pocket - to keep love flowing.",healing:"Lie in sunlight with Pyrite resting on your solar plexus for a 10-minute solar meditation. Tiger Eye held in the right hand while journaling helps Leo access truth beyond ego. Rose Quartz heart grid: place four pieces around your body for a deep heart-healing practice.",balance:"You shine for others so naturally - practice shining for yourself with no audience. Create alone. Dance alone. Rest without performing rest. Let others take care of you and notice how much you resist it.",yoga:["Sun Salutation - Leo natural practice, honoring their ruling sun","Camel Pose - opens Leo magnificent heart wide","Lion Breath - Leo power breath, releases tension and awakens vitality","Bow Pose - strengthens the spine Leo carries so upright","Bridge Pose - connects Leo heart and lower body in an arch of power"],affirmation:"My light is enough. I give from overflow and receive with grace."},
"Virgo":{placement:"Keep Citrine on your desk to maintain optimistic flowing energy while you work. Place Clear Quartz points at the four corners of your bedroom to create a purifying energy grid. Carry Red Jasper in your pocket to stay grounded when your mind races.",healing:"Virgo often holds stress in the digestive system. Place Red Jasper on your lower abdomen during rest to soothe this area. Create a daily crystal-cleansing ritual at the same time each day - Virgo love of routine makes this powerful. Hold Clear Quartz to your third eye when problem-solving.",balance:"Your service to others is beautiful - your self-criticism is not. Every time you notice the inner critic, replace it with one genuine self-appreciation. Schedule play with no productive purpose. Allow meals to be pleasurable rather than just nutritious.",yoga:["Revolved Triangle - supports Virgo digestive system","Standing Forward Fold - quiets mental analysis and brings inward focus","Supine Twist - releases tension in Virgo often-tight back","Dolphin Pose - grounds nervous energy","Yoga Nidra - teaches Virgo the healing power of complete surrender"],affirmation:"I am already whole. I serve from love, not obligation."},
"Libra":{placement:"Place Rose Quartz in the relationship corner of your home (far right from front door). Keep Lapis Lazuli near your throat on a necklace to support honest self-expression. Carry Red Agate for grounded courage when making difficult decisions.",healing:"When facing a decision you struggle to make, hold Lapis Lazuli in your left hand and ask your question aloud. Sit in silence for 5 minutes and notice what rises. Balance crystal meditation: lie with Rose Quartz on heart, Lapis on throat, Red Agate in each hand for 15 minutes.",balance:"Your gift is creating harmony - your shadow is losing yourself in it. Practice stating one clear preference daily, no matter how small. This builds the self-trust muscle Libra desperately needs. Spend time in nature, music, or art without purpose.",yoga:["Tree Pose - balance made physical, Libra teacher","Warrior II - teaches Libra to take up space and commit","Dancer Pose - beauty and balance combined, pure Libra energy","Partner Yoga - Libra thrives in conscious connection","Scale Balance Flow - alternating Warrior sequences to practice decisive movement"],affirmation:"I trust my own knowing. I create balance by being true to myself first."},
"Scorpio":{placement:"Place Malachite on your heart during meditation but remove it if you feel overwhelmed - its energy is intense. Keep Black Obsidian at your front door for psychic protection. Set Amethyst in your meditation space to create a sacred energetic container.",healing:"Shadow work crystal ritual: light a candle, hold Black Obsidian, and journal about what you are afraid to face. Then hold Amethyst and write what wisdom lives beneath the fear. Place Malachite on your solar plexus for 10 minutes after emotional breakthroughs to support deep integration.",balance:"You transform everything you touch - including yourself. Allow your healing to be gentle sometimes. Not every depth needs to be plumbed today. Cultivate one relationship where you are fully transparent. Practice pleasure without agenda: swimming, music, deep breathing, long meals.",yoga:["Pigeon Pose - releases Scorpio deep hip-stored emotions","Supported Shoulderstand - Scorpio transformation pose that shifts perspective","Kundalini Breath of Fire - activates Scorpio powerful energy reserves","Yin Yoga Dragon Pose - long holds allow Scorpio to sit with intensity and breathe through it","Savasana with Eye Pillow - teaches Scorpio to trust the dark and rest in the unknown"],affirmation:"I transform with grace. My depth is my greatest gift to the world."},
"Sagittarius":{placement:"Carry Sodalite during travel - place in your bag or wear as jewelry for protection and clear thinking. Keep Tiger Eye on your desk to ground your many big ideas into focused action. Place Black Tourmaline at your home entry points when you return from adventures.",healing:"When Sagittarius feels trapped or restless, hold Sodalite and breathe deeply while visualizing your next horizon. Tiger Eye grounding practice: stand barefoot, hold the stone, and feel roots growing down from your feet - anchor the Archer. Black Tourmaline during stressful travel neutralizes anxious energy instantly.",balance:"Freedom is your birthright - obligation is your teacher. Learn to complete things before beginning the next adventure. Your body needs consistency: a simple daily movement practice keeps your spirit buoyant and your back healthy. Spend time in nature daily.",yoga:["Low Lunge - opens Sagittarius hips and thighs, their zodiac body zone","Bow Pose - the Archer own pose, strengthens and energizes","Half Moon Pose - expansive adventurous and perfectly Sagittarian","Spinal Twist Flow - keeps the active Sagittarius back mobile and pain-free","Yoga Hike - combines Sagittarius love of freedom with mindful movement"],affirmation:"I am free and I am focused. My adventures have roots."},
"Capricorn":{placement:"Place Citrine on your work desk to maintain joyful abundant energy in your professional space. Keep Fluorite nearby during complex mental work for laser focus. Place Black Kyanite on your nightstand to align your energy each night and release the weight of responsibility.",healing:"Capricorn carries the world on their shoulders. Lie down, place Fluorite on your forehead, Citrine on your heart, and Black Kyanite along your spine. Breathe for 20 minutes and consciously release each responsibility with each exhale. This crystal trio resets the overloaded Capricorn system.",balance:"Rest is not a reward for Capricorn - it is a requirement for peak performance. Schedule non-negotiable rest into your planner the same way you schedule tasks. Allow yourself to be seen as vulnerable with one trusted person. Let relationships be a priority, not an afterthought.",yoga:["Mountain Pose - Capricorn at their peak: dignified patient and enduring","Standing Poses held 10 plus breaths - builds the stamina Capricorn respects","Supported Bridge with block - relieves Capricorn chronic back tension","Yin Yoga Spine Sequence - long holds release years of stored tension","Yoga Nidra - teaches the high achiever that deep rest IS the achievement"],affirmation:"I achieve through ease as much as effort. I deserve rest."},
"Aquarius":{placement:"Place Amethyst on your crown during meditation to open channels to higher cosmic downloads. Keep Aquamarine near your throat area - desk, necklace, or altar - to enhance visionary communication. Bismuth anywhere in your home adds rainbow energy that matches Aquarius unique frequency.",healing:"Aquarius often disconnects from their body while living so much in the mind. Grounding crystal ritual: hold Aquamarine in both hands, stand barefoot, and breathe deeply 10 times feeling the earth beneath you. Amethyst crown meditation: lie down, place on crown, and invite higher guidance for 15 minutes.",balance:"You carry visions for humanity while sometimes forgetting your own human needs. Eat regularly, sleep consistently, maintain a few deep friendships. Practice receiving care gracefully. Your revolutionary ideas need a healthy vessel to emerge through. Radical self-care is a revolutionary act for Aquarius.",yoga:["Inversion Practice - feeds Aquarius love of unique perspectives","Kundalini Yoga - aligns with Aquarius higher frequency energy","Eagle Pose - grounds electric energy into focused stillness","Group Yoga - Aquarius thrives in collective healing spaces","Breathwork Pranayama - Aquarius air element benefits enormously from conscious breathing"],affirmation:"I am grounded in my body and infinite in my vision. Both are true."},
"Pisces":{placement:"Place Aquamarine near water in your home - beside a bowl of water, a fountain, or your bath. Keep Amethyst under your pillow for vivid healing dreams. Position Black Tourmaline beside your bed as a protective boundary while you sleep.",healing:"Pisces absorbs energy like a sponge. Daily energetic cleanse: stand under a shower imagining all absorbed emotions washing away, then hold Black Tourmaline and intend only my energy remains in my field. Aquamarine bath ritual: place the stone beside your bath, add sea salt, and soak while visualizing emotional healing.",balance:"Your compassion is your superpower and your kryptonite. Practice discerning between your emotions and others - they feel identical to Pisces. Create clear boundaries around your time and energy. Schedule creative expression daily: art, music, dance, or writing transforms absorbed emotion into beauty.",yoga:["Fish Pose - Pisces own pose, opens the heart and throat","Restorative Yoga - deeply nourishing for Pisces sensitive nervous system","Yoga Nidra - Pisces thrives in this dreamlike healing state","Supine Butterfly - opens hips and chest and allows deep emotional release","Ocean Breath Ujjayi Pranayama - the sound of the sea calms Pisces to their core"],affirmation:"My sensitivity is sacred. I am both the ocean and the shore."}
};

// ── CRYSTAL MEANINGS PER SIGN ────────────────────────────────────────────────
var CRYSTAL_MEANINGS={
"Aries":{"Rose Quartz":"Rose Quartz softens Aries fierce warrior energy, opening the heart to receive love as powerfully as they give it. It channels passion into compassion, helping Aries build connections that last beyond the heat of the moment.","Carnelian":"Carnelian is Aries ultimate power stone, igniting the warrior spirit and sharpening decision-making when action is needed. It aligns with Mars amplifying courage, motivation, and physical vitality.","Amethyst":"Amethyst cools Aries impulsive fire and brings spiritual depth to their bold nature. It transforms restless energy into focused intention, helping Aries lead with wisdom rather than just speed."},
"Taurus":{"Malachite":"Malachite mirrors Taurus deep earth energy while pushing through stubborn blocks. It dissolves patterns that no longer serve, helping Taurus embrace transformation without losing stability.","Rose Quartz":"Rose Quartz deepens Taurus already profound capacity for loyalty and love. It nurtures self-worth from within, reminding this sign that they deserve the beauty they create for others.","Citrine":"Citrine aligns perfectly with Taurus desire for material security and prosperity. Known as the merchant stone, it attracts steady sustainable abundance that grows and endures."},
"Gemini":{"Moonstone":"Moonstone helps Gemini access their deeper emotional intelligence beneath the brilliant mental chatter. It balances the dual nature of this sign, bringing harmony between both sides Gemini constantly navigates.","Labradorite":"Labradorite is Gemini magic stone - it protects their sensitive aura while amplifying natural gifts of communication. It helps Gemini discern truth from illusion and use their quick mind with wisdom.","Black Onyx":"Black Onyx grounds Gemini scattered energy, providing focus and mental stamina to follow ideas through to completion. It shields the restless Gemini mind from overthinking."},
"Cancer":{"Black Obsidian":"Black Obsidian gives Cancer the psychic protection their sensitive field desperately needs. It creates a shield against absorbing others emotions while helping Cancer confront and heal their own deep wounds.","Selenite":"Selenite purifies Cancer energy field of accumulated emotions absorbed from everyone around them. Its pure white light connects Cancer to higher guidance and brings profound peace.","Moonstone":"Moonstone is Cancer birthstone by nature - ruled by the moon just like this sign. It amplifies legendary intuition and deepens emotional intelligence, helping flow with life cycles."},
"Leo":{"Pyrite":"Pyrite amplifies Leo natural magnetism and attracts the success and recognition this sign was born for. Its golden energy aligns with Leo ruling sun, building unshakeable confidence and shielding against self-doubt.","Tiger's Eye":"Tiger Eye grounds Leo magnificent vision into practical reality. It balances natural pride with wisdom and discernment, ensuring bold leadership inspires rather than overwhelms.","Rose Quartz":"Rose Quartz opens Leo generous heart even wider, shifting focus from being admired to genuinely loving. It softens the ego just enough to create deeper more authentic connections."},
"Virgo":{"Citrine":"Citrine quiets Virgo relentless inner critic with warm optimistic energy. It reminds this perfectionist sign that joy comes from appreciating what is, not endlessly fixing what is not.","Red Jasper":"Red Jasper gives Virgo physical endurance and emotional stability to sustain tireless service without burning out. It grounds analytical mind in body-wisdom, encouraging rest as much as productivity.","White Quartz":"Clear Quartz amplifies every gift Virgo already possesses - precision, healing ability, and discernment - while bringing crystal clarity to complex problems. It is the master healer aligned with Virgo healing nature."},
"Libra":{"Rose Quartz":"Rose Quartz is Libra highest ally, resonating perfectly with Venus their ruling planet. It attracts loving relationships and helps Libra remember that harmony begins within before it can be created around them.","Lapis Lazuli":"Lapis Lazuli empowers Libra to speak truth even when honesty might disturb the peace they crave. It connects them to deep wisdom, giving courage to decide from inner knowing rather than people-pleasing.","Red Agate":"Red Agate gives Libra the grounded energy and quiet courage to stand their ground. It helps this diplomatic sign overcome indecision and bring courageous energy to their own needs."},
"Scorpio":{"Malachite":"Malachite is Scorpio transformation stone - it pulls hidden emotional wounds to the surface so they can be healed rather than suppressed. It accelerates natural death-and-rebirth cycles, making each transformation more powerful.","Amethyst":"Amethyst channels Scorpio intense psychic sensitivity into spiritual wisdom. It protects against absorbing dark energies during deep emotional work and validates intuitive downloads as genuine guidance.","Black Obsidian":"Black Obsidian is Scorpio truth mirror - it reveals what is hidden both within themselves and in situations around them. It provides psychic protection during shadow work."},
"Sagittarius":{"Sodalite":"Sodalite is Sagittarius truth compass, deepening philosophical seeking with genuine intellectual clarity. It helps the Archer distinguish between inspired optimism and wishful thinking.","Tiger's Eye":"Tiger Eye gives Sagittarius the focused grounded energy to actually complete the adventures they begin. It balances expansive fire with earthy practicality, helping manifest visions rather than just dreaming them.","Black Tourmaline":"Black Tourmaline protects the free-spirited Sagittarius on all journeys - literal and spiritual. It creates an energetic shield that allows free exploration without absorbing dense energies encountered along the way."},
"Capricorn":{"Citrine":"Citrine infuses Capricorn disciplined work ethic with joy and abundant energy. It reminds this sign that prosperity flows most freely when approached with gratitude, not just grinding determination.","Fluorite":"Fluorite organizes Capricorn already formidable mind into laser-sharp focus. It clears mental clutter and helps make strategic decisions with both analytical precision and intuitive wisdom.","Black Kyanite":"Black Kyanite instantly aligns all of Capricorn energy centers, sweeping away stress that builds from carrying so much responsibility. Like Capricorn, it transmutes rather than accumulates negativity."},
"Aquarius":{"Amethyst":"Amethyst connects Aquarius to the higher frequencies their consciousness naturally reaches for. It transforms electric mental energy into spiritual wisdom, helping understand that true revolution begins with inner awakening.","Bismuth":"Bismuth is uniquely Aquarian - a rainbow-spectrum crystal that celebrates individuality and interconnectedness simultaneously. It eases the loneliness this sign sometimes feels from being so ahead of their time.","Aquamarine":"Aquamarine brings soothing clarity to Aquarius electric mind and enhances their ability to communicate visionary ideas in ways others can actually receive and understand."},
"Pisces":{"Aquamarine":"Aquamarine is Pisces ancient sea stone, connecting this sign to the deep oceanic wisdom they carry in their soul. It brings emotional clarity and gentle courage, helping navigate between inner dream world and outer reality.","Amethyst":"Amethyst deepens Pisces extraordinary spiritual connection and enhances dream recall and psychic ability. It provides a protective violet shield around their porous energy field.","Black Tourmaline":"Black Tourmaline is Pisces essential grounding anchor, protecting the most spiritually open sign in the zodiac from absorbing negativity. It creates a powerful boundary that lets Pisces give compassionately."}
};

