var currentSpread="single";
var drawnCards=[];

function selectSpread(type,btn){
  currentSpread=type;
  document.querySelectorAll('.spread-btn').forEach(function(b){b.classList.remove('on');});
  btn.classList.add('on');
  document.getElementById('cards-area').innerHTML='';
  document.getElementById('reading-result').innerHTML='';
  drawnCards=[];
  var ppf=document.getElementById('ppf-tabs');
  ppf.style.display=(type==='three')?'flex':'none';
  var lh=document.getElementById('love-header');
  lh.style.display=(type==='love')?'block':'none';
}

function shuffle(arr){var a=arr.slice();for(var i=a.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=a[i];a[i]=a[j];a[j]=t;}return a;}

function drawCards(){
  var spread=SPREADS[currentSpread];
  var count=spread.positions.length;
  var shuffled=shuffle(DECK);
  drawnCards=[];
  for(var i=0;i<count;i++){var c=Object.assign({},shuffled[i]);c.reversed=Math.random()<0.25;c.position=spread.positions[i];drawnCards.push(c);}
  var btn=document.getElementById('draw-btn');
  btn.disabled=true;
  document.getElementById('reading-result').innerHTML='';
  renderFaceDown(count);
  var delay=400;
  drawnCards.forEach(function(card,i){setTimeout(function(){flipCard(i);},delay*(i+1));});
  setTimeout(function(){btn.disabled=false;getAIReading();},delay*(count+1)+600);
}

function cardSVG(card){
  var bg=card.bg,fg=card.fg||'white';
  var em=card.type==='minor'?card.num:'\u2728';
  return '<svg viewBox="0 0 110 165" xmlns="http://www.w3.org/2000/svg"><rect width="110" height="165" fill="'+bg+'"/><rect x="5" y="5" width="100" height="155" rx="7" fill="'+fg+'" opacity=".07"/><rect x="9" y="9" width="92" height="147" rx="5" fill="none" stroke="'+fg+'" stroke-width=".8" opacity=".2"/><text x="55" y="90" text-anchor="middle" font-size="32" opacity=".5">'+em+'</text><text x="8" y="20" font-family="Georgia,serif" font-size="9" fill="'+fg+'" opacity=".6">'+card.num+'</text></svg>';
}

function renderFaceDown(count){
  var area=document.getElementById('cards-area');
  area.innerHTML='';
  for(var i=0;i<count;i++){
    var wrap=document.createElement('div');
    wrap.className='tarot-card-wrap';
    var lbl=document.createElement('div');
    lbl.className='tarot-pos-label';
    lbl.textContent=drawnCards[i].position;
    var card=document.createElement('div');
    card.className='tarot-card';
    card.id='tc-'+i;
    card.innerHTML='<div class="tarot-card-inner"><div class="tarot-card-back">\u2728</div><div class="tarot-card-front"></div></div>';
    wrap.appendChild(lbl);
    wrap.appendChild(card);
    area.appendChild(wrap);
  }
}

function flipCard(i){
  var cd=drawnCards[i];
  var el=document.getElementById('tc-'+i);
  if(!el)return;
  var front=el.querySelector('.tarot-card-front');
  front.innerHTML='<div class="card-art" style="'+(cd.reversed?'transform:rotate(180deg)':'')+'">'+cardSVG(cd)+'<div class="card-numeral">'+cd.num+'</div>'+(cd.reversed?'<div class="card-reversed-badge">Reversed</div>':'')+'</div><div class="card-footer"><div class="card-name-small">'+cd.name+'</div></div>';
  el.classList.add('flipped');
}

function getAIReading(){
  var result=document.getElementById('reading-result');
  result.innerHTML='<div class="reading-loading"><div class="read-spin"></div><div style="color:#a78bfa;font-size:.9rem">The cards are speaking...</div></div>';
  var question=document.getElementById('tarot-question').value.trim();
  var spread=SPREADS[currentSpread];
  var isLove=(currentSpread==='love');
  var cardList=drawnCards.map(function(c,i){return spread.positions[i]+': '+c.name+(c.reversed?' (Reversed)':'');}).join(', ');
  var prompt='You are a wise, compassionate tarot reader. Do a '+spread.label+' tarot reading.'+(isLove?' Focus on love and relationships.':'')+(question?' The querent asks: "'+question+'"':' This is a general reading.')+' Cards: '+cardList+'. Return ONLY valid JSON: {"overall":"2-3 sentences","cards":[{"card":"name","position":"position","message":"1-2 sentences"}],"advice":"1-2 sentences","affirmation":"short statement"}';
  callGemini(prompt,
    function(raw){
      try{renderReading(JSON.parse(raw));}
      catch(e){result.innerHTML='<div class="reading-err">The veil is thick tonight — please try again.</div>';}
    },
    function(){result.innerHTML='<div class="reading-err">The veil is thick tonight — please try again.</div>';}
  );
}

function renderReading(r){
  var result=document.getElementById('reading-result');
  var spread=SPREADS[currentSpread];
  var isThree=(currentSpread==='three');
  var pills=drawnCards.map(function(c,i){return '<div class="card-pill"><span>'+spread.positions[i]+':</span> '+c.name+(c.reversed?' \u2193':'')+'</div>';}).join('');
  var cardsHTML='';
  if(r.cards)r.cards.forEach(function(c,i){
    var wrap=isThree?'<div class="ppf-panel'+(i===0?' on':'')+'" id="ppfp-'+i+'">':'';
    var wrapE=isThree?'</div>':'';
    cardsHTML+=wrap+'<div class="reading-section"><div class="reading-section-title">'+c.position+' \u2014 '+c.card+'</div><div class="reading-text">'+c.message+'</div></div>'+wrapE;
  });
  var ppfNav=isThree?'<div style="display:flex;gap:7px;justify-content:center;flex-wrap:wrap;margin-bottom:16px"><button class="ppf-tab ppf-all on" id="rppf-all" onclick="switchPPFpanel(-1,this)">All Three</button><button class="ppf-tab" id="rppf-0" onclick="switchPPFpanel(0,this)">\u2190 Past</button><button class="ppf-tab" id="rppf-1" onclick="switchPPFpanel(1,this)">\u25ce Present</button><button class="ppf-tab" id="rppf-2" onclick="switchPPFpanel(2,this)">Future \u2192</button></div>':'';
  result.innerHTML='<div class="reading-card"><div class="reading-title">\u270f\ufe0f Your '+spread.label+'</div><div class="reading-spread-name">'+new Date().toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'})+'</div><div class="card-summary-row">'+pills+'</div><div class="reading-divider"></div><div class="reading-section"><div class="reading-section-title">The Overall Message</div><div class="reading-text">'+r.overall+'</div></div><div class="reading-divider"></div>'+ppfNav+cardsHTML+'<div class="reading-divider"></div><div class="reading-section"><div class="reading-section-title">Guidance</div><div class="reading-text">'+r.advice+'</div></div></div><div class="reading-affirmation">\u2728 '+r.affirmation+' \u2728</div><button class="new-reading-btn" onclick="resetReading()">\ud83d\udd04 New Reading</button>';
}

function switchPPFpanel(which,btn){
  ['all',0,1,2].forEach(function(k){var b=document.getElementById('rppf-'+k);if(b)b.classList.remove('on');});
  if(btn)btn.classList.add('on');
  document.querySelectorAll('.ppf-panel').forEach(function(p,i){p.classList.toggle('on',which===-1||i===which);});
}

function resetReading(){
  document.getElementById('cards-area').innerHTML='';
  document.getElementById('reading-result').innerHTML='';
  document.getElementById('tarot-question').value='';
  drawnCards=[];
}

buildGrid();
</script>
</body>
</html>
