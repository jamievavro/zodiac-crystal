var ZODIAC=[
  {n:"Aries",sym:"\u2648",em:"\ud83d\udc0f",el:"fire",dt:"March 21 \u2013 April 19",ds:"Aries blazes with raw fire energy \u2014 the trailblazer of the zodiac, charging ahead with fierce confidence.",tr:["Bold","Passionate","Energetic","Courageous"],af:'"I am powerful, fearless, and ready to conquer every new beginning."',cr:["Rose Quartz","Carnelian","Amethyst"]},
  {n:"Taurus",sym:"\u2649",em:"\ud83d\udc02",el:"earth",dt:"April 20 \u2013 May 20",ds:"Taurus moves through the world like velvet \u2014 slow, luxurious, deeply rooted, with an extraordinary gift for beauty.",tr:["Sensual","Loyal","Patient","Grounded"],af:'"I am worthy of all the beautiful, abundant things life has to offer."',cr:["Malachite","Rose Quartz","Citrine"]},
  {n:"Gemini",sym:"\u264a",em:"\ud83d\udc6f",el:"air",dt:"May 21 \u2013 June 20",ds:"Gemini dances between worlds \u2014 the zodiac\u2019s quicksilver mind, always buzzing with ideas and connection.",tr:["Curious","Witty","Adaptable","Social"],af:'"My curious mind is my greatest gift \u2014 I am endlessly fascinating."',cr:["Moonstone","Labradorite","Black Onyx"]},
  {n:"Cancer",sym:"\u264b",em:"\ud83e\udd80",el:"water",dt:"June 21 \u2013 July 22",ds:"Cancer is the moon\u2019s beloved child \u2014 deeply feeling, fiercely protective, gifted with extraordinary intuition.",tr:["Intuitive","Nurturing","Protective","Empathic"],af:'"My sensitivity is a superpower. I create safe, loving spaces wherever I go."',cr:["Black Obsidian","Selenite","Moonstone"]},
  {n:"Leo",sym:"\u264c",em:"\ud83e\udd81",el:"fire",dt:"July 23 \u2013 August 22",ds:"Leo is the sun embodied \u2014 radiant, generous, and impossibly magnetic. Born to shine and inspire.",tr:["Radiant","Creative","Generous","Magnetic"],af:'"I shine my light fearlessly and inspire everyone around me."',cr:["Pyrite","Tiger&#39;s Eye","Rose Quartz"]},
  {n:"Virgo",sym:"\u264d",em:"\ud83c\udf3e",el:"earth",dt:"August 23 \u2013 September 22",ds:"Virgo tends to the world with quiet devotion and extraordinary attention to detail. The zodiac\u2019s healer.",tr:["Precise","Devoted","Analytical","Healing"],af:'"I am enough. My dedication and love make the world more beautiful."',cr:["Citrine","Red Jasper","White Quartz"]},
  {n:"Libra",sym:"\u264e",em:"\u2696\ufe0f",el:"air",dt:"September 23 \u2013 October 22",ds:"Libra is beauty made conscious \u2014 seeking harmony, fairness, and aesthetic perfection in all things.",tr:["Harmonious","Charming","Fair","Aesthetic"],af:'"I create harmony effortlessly. My presence brings beauty and peace."',cr:["Rose Quartz","Lapis Lazuli","Red Agate"]},
  {n:"Scorpio",sym:"\u264f",em:"\ud83e\udd82",el:"water",dt:"October 23 \u2013 November 21",ds:"Scorpio dwells in the depths most signs fear \u2014 the zodiac\u2019s alchemist, transforming pain into power.",tr:["Intense","Transformative","Psychic","Loyal"],af:'"I rise, transform, and emerge more powerful with every cycle."',cr:["Malachite","Amethyst","Black Obsidian"]},
  {n:"Sagittarius",sym:"\u2650",em:"\ud83c\udff9",el:"fire",dt:"November 22 \u2013 December 21",ds:"Sagittarius is the cosmos\u2019 wanderer \u2014 arrow always aimed at the next horizon, heart hungry for truth.",tr:["Adventurous","Philosophical","Free","Optimistic"],af:'"The universe is my playground. I expand, explore, and embrace every adventure."',cr:["Sodalite","Tiger&#39;s Eye","Black Tourmaline"]},
  {n:"Capricorn",sym:"\u2651",em:"\ud83d\udc10",el:"earth",dt:"December 22 \u2013 January 19",ds:"Capricorn is the mountain itself \u2014 patient, enduring, destined for the summit. Building empires quietly.",tr:["Disciplined","Ambitious","Wise","Persistent"],af:'"I build my dreams with patience and purpose. Success is my birthright."',cr:["Citrine","Fluorite","Black Kyanite"]},
  {n:"Aquarius",sym:"\u2652",em:"\ud83c\udffa",el:"air",dt:"January 20 \u2013 February 18",ds:"Aquarius is the future walking among us \u2014 a visionary humanitarian vibrating at a frequency all their own.",tr:["Visionary","Humanitarian","Original","Electric"],af:'"I am a beacon of innovation. My unique vision is changing the world."',cr:["Amethyst","Bismuth","Aquamarine"]},
  {n:"Pisces",sym:"\u2653",em:"\ud83d\udc1f",el:"water",dt:"February 19 \u2013 March 20",ds:"Pisces swims between worlds \u2014 the most psychic, empathic, and dreamy soul in the zodiac.",tr:["Dreamy","Empathic","Spiritual","Creative"],af:'"My sensitivity is sacred. I flow with life\'s currents and trust the universe completely."',cr:["Aquamarine","Amethyst","Black Tourmaline"]}
];
