var YOGA_POSES={
"Warrior I":{sanskrit:"Virabhadrasana I",duration:"Hold 30-60 seconds each side",benefits:"Builds strength and grounded confidence. Opens hips and chest while developing focused courage.",steps:["Stand tall, step left foot back 3-4 feet","Turn left foot out 45 degrees, right foot forward","Bend right knee to 90 degrees over ankle","Raise both arms overhead, palms facing each other","Square hips forward, lift chest","Hold 5-10 deep breaths, then switch sides"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#7f1d1d" rx="10"/><line x1="15" y1="138" x2="105" y2="138" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="30" cy="139" rx="10" ry="3" fill="rgba(255,255,255,.4)"/><ellipse cx="82" cy="139" rx="10" ry="3" fill="rgba(255,255,255,.4)"/><line x1="30" y1="138" x2="55" y2="98" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="82" y1="138" x2="82" y2="108" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="82" y1="108" x2="55" y2="98" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="55" y1="98" x2="58" y2="68" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="58" y1="75" x2="42" y2="50" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="58" y1="75" x2="74" y2="50" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="42" cy="48" r="4" fill="white"/><circle cx="74" cy="48" r="4" fill="white"/><circle cx="59" cy="58" r="10" fill="white"/><circle cx="59" cy="58" r="7" fill="#7f1d1d"/></svg>'},
"Camel Pose":{sanskrit:"Ustrasana",duration:"Hold 20-40 seconds, repeat 2-3 times",benefits:"Opens the heart and throat. Counteracts stress-hunching and softens defended emotions. Heart opener for Leo and Aries.",steps:["Kneel on floor, knees hip-width apart","Place hands on lower back, fingers pointing down","Inhale and lift chest toward the ceiling","Gently tilt head back if comfortable","Reach hands back to grasp heels one at a time","Hold 5 breaths, come out slowly on exhale"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#78350f" rx="10"/><line x1="20" y1="138" x2="100" y2="138" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="45" cy="138" rx="8" ry="3" fill="rgba(255,255,255,.4)"/><ellipse cx="75" cy="138" rx="8" ry="3" fill="rgba(255,255,255,.4)"/><line x1="45" y1="137" x2="45" y2="105" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="75" y1="137" x2="75" y2="105" stroke="white" stroke-width="5" stroke-linecap="round"/><path d="M45,105 Q30,75 55,55 Q75,40 80,65 Q85,85 75,105" fill="none" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="50" y1="80" x2="45" y2="110" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="70" y1="72" x2="75" y2="108" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="55" cy="48" r="10" fill="white"/><circle cx="55" cy="48" r="7" fill="#78350f"/></svg>'},
"Child Pose":{sanskrit:"Balasana",duration:"Hold 1-5 minutes",benefits:"The ultimate resting pose. Releases tension in back, hips, and shoulders. Signals safety to the nervous system.",steps:["Kneel on mat, big toes touching, knees apart","Sit back onto your heels","Exhale and fold forward, arms extended in front","Rest forehead gently on the mat","Breathe deeply into your back body","Stay 1-5 minutes, releasing with each exhale"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#2d1b4e" rx="10"/><line x1="10" y1="118" x2="110" y2="118" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><path d="M20,116 Q35,100 55,98 Q75,96 90,98 Q100,100 105,110" fill="none" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="20" y1="115" x2="12" y2="102" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="22" y1="114" x2="8" y2="100" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="10" cy="99" r="4" fill="white"/><circle cx="7" cy="100" r="4" fill="white"/><circle cx="25" cy="108" r="9" fill="white"/><circle cx="25" cy="108" r="6" fill="#2d1b4e"/><ellipse cx="92" cy="112" rx="12" ry="7" fill="rgba(255,255,255,.5)"/><ellipse cx="88" cy="116" rx="14" ry="4" fill="rgba(255,255,255,.35)"/></svg>'},
"Mountain Pose":{sanskrit:"Tadasana",duration:"Hold 30 seconds to 1 minute",benefits:"Foundation of all standing poses. Builds posture awareness and steady grounded presence perfect for Taurus and Capricorn.",steps:["Stand with feet together or hip-width apart","Spread all ten toes wide on the mat","Engage thighs gently, lift kneecaps","Lengthen spine, lift crown toward ceiling","Roll shoulders back and down","Arms at sides, palms forward, breathe deeply"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#052e16" rx="10"/><line x1="25" y1="138" x2="95" y2="138" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="52" cy="139" rx="7" ry="3" fill="rgba(255,255,255,.4)"/><ellipse cx="68" cy="139" rx="7" ry="3" fill="rgba(255,255,255,.4)"/><line x1="52" y1="138" x2="54" y2="100" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="68" y1="138" x2="66" y2="100" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="54" y1="100" x2="60" y2="60" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="58" y1="72" x2="44" y2="96" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="62" y1="72" x2="76" y2="96" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="44" cy="97" r="4" fill="white"/><circle cx="76" cy="97" r="4" fill="white"/><circle cx="60" cy="49" r="11" fill="white"/><circle cx="60" cy="49" r="7" fill="#052e16"/></svg>'},
"Tree Pose":{sanskrit:"Vrksasana",duration:"Hold 30-60 seconds each side",benefits:"Develops balance, focus, and inner stillness. Teaches the mind to be present. Perfect for Libra and Taurus needing centered energy.",steps:["Begin in Mountain Pose","Shift weight into left foot","Bend right knee, place sole on inner left thigh or calf","Bring palms together at heart or raise arms overhead","Fix gaze on one still point in front of you","Hold 30-60 seconds, repeat on other side"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#1a3a5c" rx="10"/><line x1="25" y1="138" x2="95" y2="138" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="60" cy="139" rx="9" ry="3" fill="rgba(255,255,255,.45)"/><line x1="60" y1="138" x2="60" y2="95" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="115" x2="78" y2="128" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="78" y1="128" x2="78" y2="115" stroke="white" stroke-width="4" stroke-linecap="round"/><ellipse cx="78" cy="115" rx="5" ry="3" fill="rgba(255,255,255,.5)"/><line x1="60" y1="95" x2="60" y2="62" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="72" x2="48" y2="50" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="72" x2="72" y2="50" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="48" y1="50" x2="72" y2="50" stroke="white" stroke-width="3" stroke-linecap="round"/><circle cx="60" cy="51" r="11" fill="white"/><circle cx="60" cy="51" r="7" fill="#1a3a5c"/></svg>'},
"Pigeon Pose":{sanskrit:"Eka Pada Rajakapotasana",duration:"Hold 1-3 minutes each side",benefits:"Deepest hip opener in yoga. Releases stored emotions especially grief and fear held in the hips. Essential for Scorpio and Cancer.",steps:["Start in Downward Facing Dog","Bring right knee forward toward right wrist","Slide right foot toward left wrist, leg rotated outward","Extend left leg straight back","Square hips toward mat as much as possible","Fold forward over right shin and breathe deeply"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#1e0e38" rx="10"/><line x1="10" y1="128" x2="110" y2="128" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><line x1="95" y1="127" x2="65" y2="105" stroke="white" stroke-width="5" stroke-linecap="round"/><path d="M35,127 Q45,120 55,115 Q65,110 65,105" fill="none" stroke="white" stroke-width="5" stroke-linecap="round"/><path d="M65,105 Q50,100 35,95 Q25,92 20,88" fill="none" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="35" y1="98" x2="15" y2="95" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="35" y1="96" x2="16" y2="88" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="22" cy="83" r="9" fill="white"/><circle cx="22" cy="83" r="6" fill="#1e0e38"/><ellipse cx="97" cy="128" rx="8" ry="3" fill="rgba(255,255,255,.4)"/></svg>'},
"Seated Forward Fold":{sanskrit:"Paschimottanasana",duration:"Hold 1-3 minutes",benefits:"Calms nervous system profoundly. Stretches entire back body. Helps release mental tension and perfectionism held by Virgo.",steps:["Sit on floor with legs extended straight forward","Flex feet, press through heels","Inhale to lengthen spine, lift chest","Exhale and hinge forward from hips not waist","Reach for feet, ankles, or shins without strain","Let head hang heavy, breathe into the back of legs"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#14532d" rx="10"/><line x1="15" y1="118" x2="110" y2="118" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><line x1="25" y1="115" x2="100" y2="115" stroke="white" stroke-width="7" stroke-linecap="round"/><ellipse cx="101" cy="115" rx="5" ry="3" fill="white"/><path d="M25,115 Q30,95 45,85 Q60,76 80,75" fill="none" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="40" y1="87" x2="95" y2="110" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="42" y1="83" x2="97" y2="108" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="98" cy="110" r="4" fill="white"/><circle cx="40" cy="78" r="9" fill="white"/><circle cx="40" cy="78" r="6" fill="#14532d"/></svg>'},
"Legs Up the Wall":{sanskrit:"Viparita Karani",duration:"5-20 minutes",benefits:"Ultimate nervous system reset. Reverses blood flow, calms anxiety, reduces stress hormones. Healing for Cancer, Virgo and all earth signs.",steps:["Sit sideways next to a wall","Swing legs up as you lower back to the floor","Scoot hips as close to wall as comfortable","Let legs rest straight up the wall","Arms out to sides, palms facing up","Close eyes and breathe naturally for 5-20 minutes"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0f0f2e" rx="10"/><line x1="100" y1="10" x2="100" y2="155" stroke="rgba(255,255,255,.35)" stroke-width="3"/><line x1="10" y1="118" x2="105" y2="118" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><line x1="100" y1="35" x2="78" y2="118" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="100" y1="55" x2="82" y2="118" stroke="white" stroke-width="6" stroke-linecap="round"/><ellipse cx="100" cy="34" rx="4" ry="6" fill="rgba(255,255,255,.5)"/><ellipse cx="100" cy="54" rx="4" ry="6" fill="rgba(255,255,255,.5)"/><ellipse cx="80" cy="119" rx="15" ry="5" fill="rgba(255,255,255,.35)"/><line x1="80" y1="118" x2="40" y2="118" stroke="white" stroke-width="7" stroke-linecap="round"/><line x1="60" y1="116" x2="55" y2="108" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="58" y1="116" x2="30" y2="112" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="32" cy="115" r="9" fill="white"/><circle cx="32" cy="115" r="6" fill="#0f0f2e"/></svg>'},
"Warrior II":{sanskrit:"Virabhadrasana II",duration:"Hold 30-60 seconds each side",benefits:"Builds strength and teaches commitment. Develops courage to hold a position without wavering. Strengthens legs and opens hips.",steps:["Stand with feet wide apart about 4 feet","Turn right foot out 90 degrees, left foot slightly in","Bend right knee over right ankle, thigh parallel to floor","Extend arms wide to the sides at shoulder height","Gaze over right fingertips, keep chest open","Hold 30-60 seconds, repeat on left side"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#3b0764" rx="10"/><line x1="8" y1="138" x2="112" y2="138" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="20" cy="139" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><ellipse cx="98" cy="139" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><line x1="20" y1="138" x2="42" y2="100" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="98" y1="138" x2="80" y2="115" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="80" y1="115" x2="42" y2="100" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="58" y1="100" x2="60" y2="65" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="58" y1="75" x2="18" y2="75" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="75" x2="102" y2="75" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="16" cy="75" r="4" fill="white"/><circle cx="104" cy="75" r="4" fill="white"/><circle cx="62" cy="54" r="11" fill="white"/><circle cx="64" cy="54" r="7" fill="#3b0764"/></svg>'},
"Supine Twist":{sanskrit:"Supta Matsyendrasana",duration:"Hold 1-2 minutes each side",benefits:"Detoxifies the spine and organs. Releases lower back tension Virgo and Capricorn carry. Calms the nervous system completely.",steps:["Lie flat on your back","Hug right knee into chest","Let right knee fall across body to the left","Extend right arm out to the right, look right","Keep both shoulders grounded on the mat","Breathe deeply into the twist, then switch sides"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0c1a3e" rx="10"/><line x1="10" y1="115" x2="110" y2="115" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><line x1="20" y1="112" x2="90" y2="112" stroke="white" stroke-width="7" stroke-linecap="round"/><line x1="85" y1="112" x2="105" y2="112" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="112" x2="45" y2="92" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="45" y1="92" x2="30" y2="112" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="70" y1="108" x2="105" y2="95" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="106" cy="94" r="4" fill="white"/><line x1="50" y1="108" x2="20" y2="100" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="22" cy="110" r="9" fill="white"/><circle cx="24" cy="110" r="6" fill="#0c1a3e"/></svg>'},
"Eagle Pose":{sanskrit:"Garudasana",duration:"Hold 30-60 seconds each side",benefits:"The ultimate concentration pose. Wraps and compresses then releases the whole body. Perfect for Gemini and Aquarius to find laser focus from scattered energy.",steps:["Begin in Mountain Pose","Bend knees slightly, lift right foot","Cross right thigh over left thigh","Hook right foot behind left calf if possible","Cross left arm over right, wrap forearms, lift hands","Squeeze everything toward center and hold"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0c2a4a" rx="10"/><line x1="35" y1="138" x2="85" y2="138" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="60" cy="139" rx="9" ry="3" fill="rgba(255,255,255,.45)"/><line x1="60" y1="138" x2="60" y2="110" stroke="white" stroke-width="7" stroke-linecap="round"/><line x1="60" y1="110" x2="58" y2="92" stroke="white" stroke-width="6" stroke-linecap="round"/><path d="M60,120 Q72,118 70,108 Q68,100 60,110" fill="none" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="58" y1="92" x2="60" y2="62" stroke="white" stroke-width="6" stroke-linecap="round"/><path d="M52,78 Q58,70 68,72 Q75,74 72,80 Q68,86 60,82 Q52,78 52,72" fill="none" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="68" x2="60" y2="55" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="60" cy="50" r="11" fill="white"/><circle cx="60" cy="50" r="7" fill="#0c2a4a"/></svg>'},
"Low Lunge":{sanskrit:"Anjaneyasana",duration:"Hold 30-60 seconds each side",benefits:"Opens hip flexors tight from sitting and stress. Sagittarius body zone - keeps the hips open for all of life journeys ahead.",steps:["From standing, step right foot forward into a lunge","Lower left knee gently to the mat","Slide left knee back until you feel hip flexor stretch","Lift arms overhead, palms facing each other","Open chest, slight backbend if comfortable","Hold 30-60 seconds, then switch sides"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#451a03" rx="10"/><line x1="10" y1="132" x2="110" y2="132" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="25" cy="133" rx="10" ry="3" fill="rgba(255,255,255,.4)"/><line x1="25" y1="132" x2="50" y2="100" stroke="white" stroke-width="5" stroke-linecap="round"/><ellipse cx="88" cy="133" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><line x1="88" y1="132" x2="72" y2="100" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="72" y1="100" x2="50" y2="100" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="100" x2="62" y2="65" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="62" y1="72" x2="50" y2="50" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="62" y1="72" x2="74" y2="50" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="50" cy="48" r="4" fill="white"/><circle cx="74" cy="48" r="4" fill="white"/><circle cx="62" cy="55" r="10" fill="white"/><circle cx="62" cy="55" r="7" fill="#451a03"/></svg>'},"Headstand":{sanskrit:"Sirsasana",duration:"Work up to 1-2 minutes",benefits:"Inverts the body and calms the mind. Builds the focus and courage Aries loves. Practice against a wall first.",steps:["Start on hands and knees, interlace fingers on mat","Place crown of head on mat cradled by hands","Walk feet in close, lifting hips high","Tuck knees to chest then slowly extend legs up","Breathe steadily and hold, come down before straining"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#7f1d1d" rx="10"/><line x1="20" y1="140" x2="100" y2="140" stroke="rgba(255,255,255,.35)" stroke-width="2"/><circle cx="60" cy="132" r="9" fill="white"/><circle cx="60" cy="132" r="6" fill="#7f1d1d"/><ellipse cx="60" cy="140" rx="14" ry="4" fill="rgba(255,255,255,.4)"/><line x1="60" y1="123" x2="60" y2="80" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="95" x2="45" y2="112" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="95" x2="75" y2="112" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="80" x2="48" y2="50" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="80" x2="72" y2="50" stroke="white" stroke-width="5" stroke-linecap="round"/><ellipse cx="48" cy="47" rx="5" ry="3" fill="rgba(255,255,255,.5)"/><ellipse cx="72" cy="47" rx="5" ry="3" fill="rgba(255,255,255,.5)"/></svg>'},
"Lion Breath":{sanskrit:"Simhasana",duration:"5-10 cycles",benefits:"Releases jaw face and throat tension. Expels stale energy. Aries and Leo use this to release frustration and awaken vitality.",steps:["Sit comfortably, hands on knees","Inhale deeply through the nose","Open mouth wide, stick tongue out toward chin","Exhale forcefully with a HAAA sound","Eyes wide, gaze up between eyebrows","Repeat 5-10 times then breathe naturally"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#c2410c" rx="10"/><circle cx="60" cy="65" r="22" fill="white"/><circle cx="60" cy="65" r="16" fill="#c2410c"/><circle cx="53" cy="61" r="4" fill="white"/><circle cx="67" cy="61" r="4" fill="white"/><ellipse cx="60" cy="73" rx="8" ry="5" fill="white"/><line x1="60" y1="78" x2="60" y2="90" stroke="white" stroke-width="3" stroke-linecap="round"/><line x1="60" y1="95" x2="60" y2="130" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="110" x2="38" y2="122" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="110" x2="82" y2="122" stroke="white" stroke-width="4" stroke-linecap="round"/></svg>'},
"Goddess Pose":{sanskrit:"Utkata Konasana",duration:"Hold 30-60 seconds",benefits:"Awakens sensual earthy power. Opens hips and inner thighs. Perfect for grounding Taurus energy into the body.",steps:["Stand with feet wide apart, toes turned out 45 degrees","Bend knees deeply tracking over toes","Lower until thighs approach parallel to floor","Bring hands to heart or raise arms up","Lift chest and breathe powerfully","Hold and pulse gently to deepen the stretch"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#52400a" rx="10"/><line x1="8" y1="138" x2="112" y2="138" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="18" cy="139" rx="10" ry="3" fill="rgba(255,255,255,.4)"/><ellipse cx="102" cy="139" rx="10" ry="3" fill="rgba(255,255,255,.4)"/><line x1="18" y1="138" x2="42" y2="108" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="102" y1="138" x2="78" y2="108" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="42" y1="108" x2="60" y2="100" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="78" y1="108" x2="60" y2="100" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="100" x2="60" y2="64" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="78" x2="36" y2="62" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="78" x2="84" y2="62" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="60" cy="53" r="11" fill="white"/><circle cx="60" cy="53" r="7" fill="#52400a"/></svg>'},
"Savasana":{sanskrit:"Savasana",duration:"5-15 minutes",benefits:"The most important pose. Total relaxation allows the nervous system to fully integrate the practice. Non-negotiable for every sign.",steps:["Lie flat on your back, arms resting by sides","Let feet fall open naturally","Close your eyes gently","Release all effort from every single muscle","Breathe naturally without any control","Stay completely still for 5-15 minutes and receive"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#1a2a3a" rx="10"/><line x1="10" y1="108" x2="110" y2="108" stroke="rgba(255,255,255,.25)" stroke-width="1.5"/><line x1="18" y1="105" x2="95" y2="105" stroke="white" stroke-width="8" stroke-linecap="round"/><ellipse cx="15" cy="105" rx="7" ry="4" fill="rgba(255,255,255,.45)"/><ellipse cx="98" cy="105" rx="7" ry="4" fill="rgba(255,255,255,.45)"/><line x1="40" y1="103" x2="30" y2="93" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="70" y1="103" x2="82" y2="93" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="29" cy="92" r="4" fill="white"/><circle cx="83" cy="92" r="4" fill="white"/><circle cx="18" cy="103" r="9" fill="white"/><circle cx="18" cy="103" r="6" fill="#1a2a3a"/></svg>'},
"Alternate Nostril Breathing":{sanskrit:"Nadi Shodhana",duration:"5-10 minutes",benefits:"Balances left and right brain hemispheres. Instantly calms anxiety. Perfect for Gemini restless dual-natured mind.",steps:["Sit comfortably with spine tall","Bring right hand up, fold index and middle fingers","Close right nostril with thumb, inhale slowly through left","Close left nostril with ring finger, open right, exhale","Inhale right, then switch and exhale left","This is one round - continue 5 to 10 minutes"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0c3a5c" rx="10"/><circle cx="60" cy="55" r="22" fill="white"/><circle cx="60" cy="55" r="16" fill="#0c3a5c"/><circle cx="53" cy="50" r="4" fill="white"/><circle cx="67" cy="50" r="4" fill="white"/><line x1="60" y1="77" x2="60" y2="110" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="88" x2="38" y2="80" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="88" x2="82" y2="68" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="84" cy="66" r="6" fill="rgba(255,255,255,.6)"/><line x1="60" y1="110" x2="38" y2="135" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="110" x2="82" y2="135" stroke="white" stroke-width="5" stroke-linecap="round"/><ellipse cx="38" cy="137" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><ellipse cx="82" cy="137" rx="9" ry="3" fill="rgba(255,255,255,.4)"/></svg>'},
"Butterfly Pose":{sanskrit:"Baddha Konasana",duration:"2-5 minutes",benefits:"Opens inner thighs and hips. Releases emotional tension in pelvic area. Calms the restless Gemini nervous system.",steps:["Sit on floor, bring soles of feet together","Let knees fall open like butterfly wings","Hold feet with both hands and sit tall","Gently press knees toward floor without forcing","Fold forward slowly if comfortable","Breathe and hold 2-5 minutes"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0c2a3a" rx="10"/><line x1="10" y1="128" x2="110" y2="128" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="60" cy="122" rx="14" ry="8" fill="rgba(255,255,255,.4)"/><line x1="60" y1="122" x2="22" y2="128" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="122" x2="98" y2="128" stroke="white" stroke-width="5" stroke-linecap="round"/><ellipse cx="22" cy="129" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><ellipse cx="98" cy="129" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><line x1="60" y1="115" x2="60" y2="78" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="95" x2="36" y2="108" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="95" x2="84" y2="108" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="60" cy="67" r="11" fill="white"/><circle cx="60" cy="67" r="7" fill="#0c2a3a"/></svg>'},
"Wide-Legged Forward Fold":{sanskrit:"Prasarita Padottanasana",duration:"Hold 1-2 minutes",benefits:"Grounds scattered air energy powerfully. Calms the mind by inverting the head. Stretches inner thighs and releases neck.",steps:["Stand with feet wide apart about 4 feet parallel","Inhale to lengthen spine and lift chest","Exhale and hinge forward from hips","Place hands on floor between feet","Let head hang completely heavy toward floor","Walk hands back toward feet to deepen the stretch"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0c3a2a" rx="10"/><line x1="5" y1="128" x2="115" y2="128" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="12" cy="129" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><ellipse cx="108" cy="129" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><line x1="12" y1="128" x2="48" y2="88" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="108" y1="128" x2="72" y2="88" stroke="white" stroke-width="5" stroke-linecap="round"/><path d="M48,88 Q60,75 72,88" fill="none" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="55" y1="86" x2="50" y2="105" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="65" y1="86" x2="70" y2="105" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="60" cy="80" r="9" fill="white"/><circle cx="60" cy="80" r="6" fill="#0c3a2a"/></svg>'},
"Supported Fish Pose":{sanskrit:"Matsyasana supported",duration:"3-5 minutes",benefits:"Opens the chest throat and heart completely. Releases the protective shell Cancer builds. Counteracts emotional constriction.",steps:["Sit on mat with a folded blanket or block behind you","Lie back over the support so chest opens upward","Let head rest back gently, throat completely open","Arms can rest by sides or open wide like wings","Breathe deeply into the expanding chest","Stay 3-5 minutes feeling the heart blossom open"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#1a2a5a" rx="10"/><line x1="10" y1="118" x2="110" y2="118" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><rect x="30" y="108" width="60" height="10" rx="4" fill="rgba(255,255,255,.25)"/><path d="M20,115 Q40,95 60,92 Q80,89 95,100 Q105,108 100,115" fill="none" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="25" y1="112" x2="12" y2="105" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="95" y1="110" x2="108" y2="103" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="22" cy="107" r="9" fill="white"/><circle cx="22" cy="107" r="6" fill="#1a2a5a"/></svg>'},
"Moon Salutation":{sanskrit:"Chandra Namaskar",duration:"5-10 rounds",benefits:"A cooling lunar flow perfect for Cancer. Honors the moon energy ruling this sign. Balances the emotions and feminine energy.",steps:["Begin in Mountain Pose, hands at heart center","Step wide and flow into Goddess Pose","Side lunge right hold one breath, then left","Flow through Half Moon and standing crescent","Return through center with a grounding breath","Repeat on other side for 5 to 10 complete rounds"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0f1a4e" rx="10"/><path d="M80,35 Q65,30 55,40 Q42,52 46,68 Q50,84 62,88 Q72,92 82,84 Q70,80 64,68 Q58,54 66,44 Q72,36 80,35Z" fill="rgba(255,255,255,.8)"/><line x1="10" y1="140" x2="110" y2="140" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="60" cy="141" rx="10" ry="3" fill="rgba(255,255,255,.4)"/><line x1="60" y1="140" x2="60" y2="108" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="125" x2="42" y2="132" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="125" x2="78" y2="132" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="108" x2="60" y2="78" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="90" x2="40" y2="78" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="90" x2="80" y2="78" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="60" cy="67" r="11" fill="white"/><circle cx="60" cy="67" r="7" fill="#0f1a4e"/></svg>'},
"Hip Circles in Cat-Cow":{sanskrit:"Chakravakasana variation",duration:"2-5 minutes",benefits:"Releases grief and old emotions stored in hips and lower back. Deeply soothing for Cancer and all water signs.",steps:["Come to hands and knees, wrists under shoulders","Begin gentle cat-cow: arch and round the spine","Add slow circular hip movements in big circles","Move slowly and intuitively following what feels good","Breathe into any tight areas without forcing","Continue 2-5 minutes then rest in Child Pose"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#1a3a4e" rx="10"/><line x1="10" y1="120" x2="110" y2="120" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="30" cy="121" rx="10" ry="3" fill="rgba(255,255,255,.4)"/><ellipse cx="85" cy="121" rx="10" ry="3" fill="rgba(255,255,255,.4)"/><line x1="30" y1="120" x2="32" y2="92" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="85" y1="120" x2="83" y2="92" stroke="white" stroke-width="5" stroke-linecap="round"/><path d="M32,92 Q45,75 60,72 Q75,70 83,92" fill="none" stroke="white" stroke-width="6" stroke-linecap="round"/><circle cx="60" cy="84" r="9" fill="white"/><circle cx="60" cy="84" r="6" fill="#1a3a4e"/></svg>'},
"Yin Yoga Hip Openers":{sanskrit:"Yin practice",duration:"3-5 minutes per pose",benefits:"Long held hip stretches release deeply stored emotions. The ultimate Cancer healing practice for grief fear and held feelings.",steps:["Choose poses like Butterfly, Pigeon, Dragon, or Sleeping Swan","Set a timer for 3-5 minutes per pose","Use props generously - blankets blocks and pillows","Allow yourself to completely release into each pose","If emotions arise breathe through them gently","Finish with 5 minutes of Savasana to integrate"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#1e0e38" rx="10"/><line x1="10" y1="125" x2="110" y2="125" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><line x1="95" y1="124" x2="65" y2="102" stroke="white" stroke-width="5" stroke-linecap="round"/><path d="M35,124 Q48,116 58,110 Q65,106 65,102" fill="none" stroke="white" stroke-width="5" stroke-linecap="round"/><path d="M65,102 Q50,97 35,92 Q25,89 18,84" fill="none" stroke="white" stroke-width="5" stroke-linecap="round"/><circle cx="20" cy="79" r="9" fill="white"/><circle cx="20" cy="79" r="6" fill="#1e0e38"/><ellipse cx="97" cy="125" rx="8" ry="3" fill="rgba(255,255,255,.4)"/></svg>'},
"Sun Salutation":{sanskrit:"Surya Namaskar",duration:"5-12 rounds",benefits:"Leo natural practice honoring their ruling sun. A complete moving meditation that builds heat strength and radiant energy.",steps:["Stand in Mountain Pose hands at heart center","Inhale arms overhead, exhale fold forward","Step or jump back to plank and lower down","Cobra or Upward Dog on the inhale breath","Downward Dog on the exhale hold 5 breaths","Step or jump forward, rise up, return to Mountain"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#7c2d00" rx="10"/><circle cx="60" cy="30" r="14" fill="rgba(255,200,50,.6)"/><line x1="60" y1="12" x2="60" y2="6" stroke="rgba(255,200,50,.7)" stroke-width="2"/><line x1="60" y1="48" x2="60" y2="54" stroke="rgba(255,200,50,.7)" stroke-width="2"/><line x1="42" y1="30" x2="36" y2="30" stroke="rgba(255,200,50,.7)" stroke-width="2"/><line x1="78" y1="30" x2="84" y2="30" stroke="rgba(255,200,50,.7)" stroke-width="2"/><line x1="10" y1="140" x2="110" y2="140" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="60" cy="141" rx="10" ry="3" fill="rgba(255,255,255,.4)"/><line x1="60" y1="140" x2="60" y2="105" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="120" x2="42" y2="130" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="120" x2="78" y2="130" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="105" x2="60" y2="75" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="88" x2="40" y2="75" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="88" x2="80" y2="75" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="60" cy="64" r="11" fill="white"/><circle cx="60" cy="64" r="7" fill="#7c2d00"/></svg>'},
"Bow Pose":{sanskrit:"Dhanurasana",duration:"Hold 20-30 seconds, repeat 2-3 times",benefits:"Energizes the entire spine and opens the chest. Builds courage and vitality. Leo and Sagittarius love this powerful backbend.",steps:["Lie on your stomach, arms by sides","Bend knees and reach back to grab your ankles firmly","Inhale and lift chest and thighs off the mat","Body forms a bow shape - rock gently if comfortable","Breathe into the wide open chest","Exhale and slowly release, rest between rounds"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#1a3a00" rx="10"/><line x1="10" y1="118" x2="110" y2="118" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><path d="M25,112 Q35,100 50,88 Q65,76 80,80 Q95,85 100,100 Q105,112 95,118" fill="none" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="50" y1="88" x2="28" y2="100" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="78" y1="82" x2="92" y2="95" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="50" cy="80" r="9" fill="white"/><circle cx="50" cy="80" r="6" fill="#1a3a00"/><ellipse cx="25" cy="113" rx="10" ry="4" fill="rgba(255,255,255,.5)"/><ellipse cx="95" cy="117" rx="10" ry="4" fill="rgba(255,255,255,.5)"/></svg>'},
"Bridge Pose":{sanskrit:"Setu Bandha Sarvangasana",duration:"Hold 30-60 seconds, repeat 3 times",benefits:"Opens chest and strengthens back. Creates an arch of power connecting Leo heart and lower body. Stimulates the thyroid gland.",steps:["Lie on your back, knees bent, feet flat hip-width apart","Arms alongside body with palms facing down","Press feet and arms into mat and lift hips up","Interlace fingers under back, roll shoulders under","Keep chin slightly tucked to protect your neck","Hold and breathe deeply into the lifted open chest"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#5a1a00" rx="10"/><line x1="10" y1="128" x2="110" y2="128" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="25" cy="129" rx="10" ry="4" fill="rgba(255,255,255,.45)"/><ellipse cx="88" cy="129" rx="10" ry="4" fill="rgba(255,255,255,.45)"/><line x1="25" y1="128" x2="35" y2="108" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="88" y1="128" x2="78" y2="108" stroke="white" stroke-width="6" stroke-linecap="round"/><path d="M35,108 Q50,92 60,90 Q70,88 78,108" fill="none" stroke="white" stroke-width="6" stroke-linecap="round"/><circle cx="22" cy="120" r="9" fill="white"/><circle cx="22" cy="120" r="6" fill="#5a1a00"/></svg>'},
"Revolved Triangle":{sanskrit:"Parivrtta Trikonasana",duration:"Hold 30 seconds each side",benefits:"Twists and massages digestive organs. Supports Virgo digestive system. Builds focus and detoxifies the body from inside out.",steps:["Stand with feet 3 feet apart, right foot forward","Reach left arm forward over right leg","Hinge forward and rotate, placing left hand to floor or shin","Extend right arm toward ceiling and look up if comfortable","Keep hips as level as possible throughout the pose","Hold 30 seconds then switch to the other side"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0a2a10" rx="10"/><line x1="10" y1="138" x2="110" y2="138" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="22" cy="139" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><ellipse cx="92" cy="139" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><line x1="22" y1="138" x2="45" y2="98" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="92" y1="138" x2="58" y2="98" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="52" y1="97" x2="38" y2="115" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="52" y1="97" x2="80" y2="72" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="38" cy="117" r="4" fill="white"/><circle cx="82" cy="70" r="5" fill="white"/><circle cx="52" cy="88" r="9" fill="white"/><circle cx="52" cy="88" r="6" fill="#0a2a10"/></svg>'},
"Standing Forward Fold":{sanskrit:"Uttanasana",duration:"Hold 1-2 minutes",benefits:"Completely quiets the analytical mind. Calms nervous system and releases back tension. Essential reset for overthinking Virgo.",steps:["Stand with feet hip-width apart facing forward","Inhale to lengthen spine and lift chest tall","Exhale and fold forward slowly from the hips","Bend knees generously if needed to protect back","Let head hang completely and heavily","Grab elbows or let arms hang free and breathe deeply"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#14532d" rx="10"/><line x1="25" y1="130" x2="95" y2="130" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="52" cy="131" rx="8" ry="3" fill="rgba(255,255,255,.4)"/><ellipse cx="68" cy="131" rx="8" ry="3" fill="rgba(255,255,255,.4)"/><line x1="52" y1="130" x2="50" y2="100" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="68" y1="130" x2="70" y2="100" stroke="white" stroke-width="5" stroke-linecap="round"/><path d="M50,100 Q54,82 60,75 Q66,68 70,100" fill="none" stroke="white" stroke-width="6" stroke-linecap="round"/><circle cx="60" cy="72" r="9" fill="white"/><circle cx="60" cy="72" r="6" fill="#14532d"/></svg>'},
"Dolphin Pose":{sanskrit:"Ardha Pincha Mayurasana",duration:"Hold 30-60 seconds",benefits:"Grounds nervous energy through forearms. Strengthens shoulders and core. Perfect for grounding anxious Virgo mind and body.",steps:["Come to hands and knees on the mat","Lower forearms to mat, elbows under shoulders","Interlace fingers or keep forearms parallel","Tuck toes and lift hips up and back high","Body forms an inverted V shape on forearms","Press chest gently toward knees and breathe deeply"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0a2a1a" rx="10"/><line x1="10" y1="128" x2="110" y2="128" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="30" cy="129" rx="15" ry="4" fill="rgba(255,255,255,.4)"/><line x1="22" y1="126" x2="38" y2="90" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="38" y1="90" x2="80" y2="68" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="80" y1="68" x2="88" y2="100" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="88" y1="100" x2="98" y2="128" stroke="white" stroke-width="5" stroke-linecap="round"/><ellipse cx="96" cy="129" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><circle cx="60" cy="62" r="9" fill="white"/><circle cx="60" cy="62" r="6" fill="#0a2a1a"/></svg>'},
"Yoga Nidra":{sanskrit:"Yoga Nidra",duration:"20-45 minutes",benefits:"Yogic sleep - deepest rest while remaining conscious. One hour equals four hours normal sleep. Every sign benefits deeply.",steps:["Lie down in Savasana with blanket and eye pillow","Set a sankalpa or intention - one clear sentence","Follow a guided audio through a full body scan","Stay awake but do not move - allow the deepest relaxation","Move through states between waking and sleep","Gently return to full awareness when practice ends"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0a0a2a" rx="10"/><circle cx="60" cy="45" r="18" fill="rgba(200,180,255,.2)"/><circle cx="60" cy="45" r="11" fill="rgba(200,180,255,.35)"/><circle cx="60" cy="45" r="5" fill="rgba(200,180,255,.6)"/><line x1="10" y1="108" x2="110" y2="108" stroke="rgba(255,255,255,.25)" stroke-width="1.5"/><line x1="18" y1="105" x2="96" y2="105" stroke="white" stroke-width="8" stroke-linecap="round"/><ellipse cx="15" cy="105" rx="7" ry="4" fill="rgba(255,255,255,.4)"/><ellipse cx="100" cy="105" rx="7" ry="4" fill="rgba(255,255,255,.4)"/><circle cx="18" cy="103" r="9" fill="white"/><circle cx="18" cy="103" r="6" fill="#0a0a2a"/></svg>'},
"Dancer Pose":{sanskrit:"Natarajasana",duration:"Hold 20-40 seconds each side",benefits:"The embodiment of beauty and balance together. Teaches Libra to commit to one foot - to stand their ground - while remaining graceful.",steps:["Stand in Mountain Pose and find your center","Shift weight onto left foot firmly","Bend right knee and reach back with right hand to hold ankle","Inhale and kick right foot back and up behind you","Reach left arm forward and up for balance","Fix gaze on one steady point and breathe"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#3b0764" rx="10"/><line x1="30" y1="140" x2="90" y2="140" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="55" cy="141" rx="9" ry="3" fill="rgba(255,255,255,.45)"/><line x1="55" y1="140" x2="55" y2="100" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="55" y1="100" x2="55" y2="68" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="55" y1="115" x2="75" y2="95" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="75" y1="95" x2="90" y2="75" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="58" y1="85" x2="72" y2="65" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="72" cy="63" r="4" fill="white"/><line x1="55" y1="82" x2="35" y2="70" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="33" cy="68" r="4" fill="white"/><circle cx="55" cy="57" r="11" fill="white"/><circle cx="55" cy="57" r="7" fill="#3b0764"/></svg>'},
"Partner Yoga":{sanskrit:"Partner practice",duration:"30-60 minutes",benefits:"Libra thrives in conscious connection and co-regulation. Partner yoga builds trust communication and deepens all relationships.",steps:["Face your partner and synchronize your breathing together","Hold hands or wrists in a seated forward fold","Try back-to-back seated twists breathing together","Support each other in Warrior poses for strength","Practice any pose while mirroring your partner","End with two minutes of eye gazing in silence"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#2a1a4a" rx="10"/><line x1="10" y1="130" x2="110" y2="130" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="38" cy="131" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><ellipse cx="82" cy="131" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><line x1="38" y1="130" x2="40" y2="90" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="82" y1="130" x2="80" y2="90" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="40" y1="90" x2="40" y2="62" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="80" y1="90" x2="80" y2="62" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="40" y1="75" x2="60" y2="72" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="80" y1="75" x2="60" y2="72" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="40" cy="51" r="11" fill="white"/><circle cx="40" cy="51" r="7" fill="#2a1a4a"/><circle cx="80" cy="51" r="11" fill="white"/><circle cx="80" cy="51" r="7" fill="#2a1a4a"/></svg>'},
"Scale Balance Flow":{sanskrit:"Vinyasa flow",duration:"10-15 minutes",benefits:"Flowing between Warrior sequences teaches Libra to make decisions and commit. Movement becomes the medicine for indecision.",steps:["Begin in Mountain Pose and breathe to center yourself","Flow right: Warrior I, Warrior II, then Reverse Warrior","Transition through center returning to Mountain Pose","Flow left: repeat the same sequence on left side","Add Triangle and Half Moon if comfortable and steady","End in Savasana feeling balanced and decisively calm"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#1a2a4a" rx="10"/><line x1="8" y1="138" x2="112" y2="138" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="20" cy="139" rx="9" ry="3" fill="rgba(255,255,255,.35)"/><ellipse cx="98" cy="139" rx="9" ry="3" fill="rgba(255,255,255,.35)"/><line x1="20" y1="138" x2="42" y2="100" stroke="rgba(255,255,255,.5)" stroke-width="4" stroke-linecap="round"/><line x1="98" y1="138" x2="80" y2="115" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="80" y1="115" x2="42" y2="100" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="58" y1="100" x2="60" y2="65" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="58" y1="75" x2="18" y2="75" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="75" x2="102" y2="75" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="62" cy="54" r="11" fill="white"/><circle cx="62" cy="54" r="7" fill="#1a2a4a"/></svg>'},
"Supported Shoulderstand":{sanskrit:"Salamba Sarvangasana",duration:"Hold 3-5 minutes",benefits:"Scorpio transformation pose. Completely inverts the body shifting perspective literally and energetically. Calms a turbulent mind.",steps:["Lie on your back and fold two blankets under your shoulders","Press arms firmly into mat and lift hips and legs up","Support lower back with both hands, elbows on blanket","Body should be vertical from shoulders to feet","Keep chin slightly away from chest to protect neck","Hold 3-5 minutes then come down very slowly with control"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#1e0e38" rx="10"/><line x1="20" y1="138" x2="100" y2="138" stroke="rgba(255,255,255,.3)" stroke-width="2"/><ellipse cx="60" cy="135" rx="18" ry="6" fill="rgba(255,255,255,.3)"/><line x1="55" y1="132" x2="55" y2="70" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="65" y1="132" x2="65" y2="70" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="70" x2="60" y2="38" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="55" y1="108" x2="30" y2="115" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="65" y1="108" x2="90" y2="115" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="60" cy="28" r="10" fill="white"/><circle cx="60" cy="28" r="7" fill="#1e0e38"/></svg>'},
"Kundalini Breath of Fire":{sanskrit:"Kapalabhati",duration:"1-3 minutes",benefits:"Activates powerful energy reserves and cleanses the energetic system. Scorpio uses this to clear dense emotions and awaken inner fire.",steps:["Sit comfortably with spine very straight and tall","Take a full deep inhale to prepare your breath","Begin rapid rhythmic short exhales through nose","Each exhale is an active pump of the belly in","Let the inhales happen passively and automatically","Start with 1 minute and build gradually to 3 minutes"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#1e0e38" rx="10"/><line x1="10" y1="140" x2="110" y2="140" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="60" cy="141" rx="10" ry="3" fill="rgba(255,255,255,.4)"/><line x1="60" y1="140" x2="60" y2="108" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="108" x2="60" y2="75" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="120" x2="38" y2="128" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="120" x2="82" y2="128" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="92" x2="40" y2="82" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="92" x2="80" y2="82" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="60" cy="64" r="11" fill="white"/><circle cx="60" cy="64" r="7" fill="#1e0e38"/><circle cx="60" cy="46" r="4" fill="rgba(255,150,50,.7)"/><circle cx="60" cy="36" r="3" fill="rgba(255,150,50,.4)"/></svg>'},
"Yin Yoga Dragon Pose":{sanskrit:"Dragon Pose",duration:"Hold 3-5 minutes each side",benefits:"A long deep lunge that opens hip flexors and groin deeply. Allows Scorpio to sit with intensity and breathe through discomfort.",steps:["Begin in Downward Facing Dog to start","Step right foot between your hands on the mat","Lower back knee gently to mat, slide it back far","Lower hands to floor inside the front foot","Sink hips low and breathe steadily into the tight areas","Stay 3-5 minutes then switch sides very slowly"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#2d1b4e" rx="10"/><line x1="10" y1="132" x2="110" y2="132" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="25" cy="133" rx="10" ry="3" fill="rgba(255,255,255,.4)"/><line x1="25" y1="132" x2="52" y2="100" stroke="white" stroke-width="5" stroke-linecap="round"/><ellipse cx="88" cy="133" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><line x1="88" y1="132" x2="72" y2="102" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="72" y1="102" x2="52" y2="100" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="101" x2="55" y2="72" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="55" y1="85" x2="35" y2="100" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="55" y1="83" x2="76" y2="98" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="55" cy="62" r="9" fill="white"/><circle cx="55" cy="62" r="6" fill="#2d1b4e"/></svg>'},
"Savasana with Eye Pillow":{sanskrit:"Savasana",duration:"10-20 minutes",benefits:"Teaches Scorpio to trust the dark and rest without controlling anything. The eye pillow creates a sacred cocoon of darkness.",steps:["Lie down in Savasana on your mat and settle in","Place a lavender-filled eye pillow over your eyes","Cover yourself with a soft blanket for warmth","Set a timer so you can fully and completely surrender","Release all effort - no adjusting no thinking no doing","Allow yourself to simply be still and receive deeply"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0a0520" rx="10"/><line x1="10" y1="108" x2="110" y2="108" stroke="rgba(255,255,255,.2)" stroke-width="1.5"/><line x1="18" y1="105" x2="96" y2="105" stroke="white" stroke-width="8" stroke-linecap="round"/><ellipse cx="15" cy="105" rx="7" ry="4" fill="rgba(255,255,255,.4)"/><ellipse cx="100" cy="105" rx="7" ry="4" fill="rgba(255,255,255,.4)"/><circle cx="18" cy="103" r="9" fill="white"/><ellipse cx="18" cy="101" rx="7" ry="3" fill="#7c3aed"/><line x1="40" y1="103" x2="30" y2="93" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="70" y1="103" x2="82" y2="93" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="29" cy="92" r="4" fill="white"/><circle cx="83" cy="92" r="4" fill="white"/></svg>'},
"Half Moon Pose":{sanskrit:"Ardha Chandrasana",duration:"Hold 20-40 seconds each side",benefits:"Expansive and adventurous - a perfectly Sagittarian pose. Builds strength and daring while opening the whole side body.",steps:["Begin in Warrior II on the right side","Shift weight onto right foot firmly","Reach right hand toward floor 12 inches ahead","Lift left leg parallel to the floor behind you","Open left hip and left arm toward the ceiling","Balance and breathe steadily, then switch sides"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#451a03" rx="10"/><line x1="10" y1="138" x2="110" y2="138" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="55" cy="139" rx="9" ry="3" fill="rgba(255,255,255,.45)"/><line x1="55" y1="138" x2="56" y2="98" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="56" y1="98" x2="56" y2="68" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="56" y1="102" x2="28" y2="102" stroke="white" stroke-width="5" stroke-linecap="round"/><ellipse cx="26" cy="102" rx="5" ry="3" fill="rgba(255,255,255,.5)"/><line x1="56" y1="96" x2="95" y2="78" stroke="white" stroke-width="5" stroke-linecap="round"/><ellipse cx="97" cy="77" rx="5" ry="4" fill="rgba(255,255,255,.5)"/><line x1="56" y1="85" x2="35" y2="72" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="56" y1="85" x2="78" y2="68" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="56" cy="57" r="11" fill="white"/><circle cx="56" cy="57" r="7" fill="#451a03"/></svg>'},
"Spinal Twist Flow":{sanskrit:"Parivrtta vinyasa",duration:"5-10 minutes",benefits:"Keeps spine mobile and pain-free. Essential for active Sagittarius who needs a healthy flexible back for all their adventures.",steps:["Begin seated comfortably with legs extended","Twist right: bend right knee and place foot outside left thigh","Hug right knee with left arm, right hand behind on mat","Inhale to lengthen spine, exhale to deepen the twist","Hold 1 minute feeling the release then switch sides","Flow through several twists linking breath to each movement"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#451a03" rx="10"/><line x1="15" y1="118" x2="105" y2="118" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><line x1="22" y1="115" x2="90" y2="115" stroke="white" stroke-width="7" stroke-linecap="round"/><ellipse cx="92" cy="115" rx="5" ry="3" fill="white"/><line x1="60" y1="115" x2="58" y2="92" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="55" y1="90" x2="35" y2="82" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="55" y1="86" x2="78" y2="72" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="33" cy="81" r="4" fill="white"/><circle cx="80" cy="70" r="4" fill="white"/><circle cx="50" cy="68" r="9" fill="white"/><circle cx="50" cy="68" r="6" fill="#451a03"/></svg>'},
"Yoga Hike":{sanskrit:"Moving meditation",duration:"30-90 minutes",benefits:"Combines Sagittarius love of freedom adventure and nature with mindful movement. Walking meditation in nature is yoga for this sign.",steps:["Choose a trail or nature path you genuinely love","Begin walking at your natural comfortable pace","After 5 minutes slow down and begin mindful walking","Feel each footstep and breathe in rhythm with your steps","Pause at beautiful spots to breathe deeply and simply notice","End with 5 minutes of complete stillness in nature"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0a2a0a" rx="10"/><path d="M10,140 Q30,100 50,120 Q70,140 90,100 Q100,80 110,90" fill="none" stroke="rgba(255,255,255,.3)" stroke-width="2"/><line x1="10" y1="140" x2="110" y2="140" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="62" cy="141" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><line x1="62" y1="140" x2="60" y2="110" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="125" x2="45" y2="135" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="110" x2="60" y2="80" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="92" x2="45" y2="82" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="92" x2="75" y2="85" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="60" cy="69" r="11" fill="white"/><circle cx="60" cy="69" r="7" fill="#0a2a0a"/></svg>'},
"Standing Poses held 10 plus breaths":{sanskrit:"Sthira practice",duration:"Hold each pose 10+ breaths",benefits:"Builds the stamina and mental endurance Capricorn deeply respects. Teaches that real strength comes from patience not force.",steps:["Choose 4-5 standing poses: Warrior I, II, Triangle, Tree, Mountain","Hold each pose for a minimum of 10 full deep breaths","Focus on steady even breathing not perfect alignment","Notice the mind wanting to stop - stay with it and breathe","This is exactly where Capricorn builds true inner strength","End with equal restorative time in Savasana"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#1a2a3a" rx="10"/><line x1="15" y1="138" x2="105" y2="138" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="30" cy="139" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><ellipse cx="88" cy="139" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><line x1="30" y1="138" x2="52" y2="98" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="88" y1="138" x2="68" y2="115" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="68" y1="115" x2="52" y2="98" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="58" y1="98" x2="60" y2="62" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="58" y1="78" x2="28" y2="78" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="78" x2="92" y2="78" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="60" cy="51" r="11" fill="white"/><circle cx="60" cy="51" r="7" fill="#1a2a3a"/></svg>'},
"Supported Bridge with block":{sanskrit:"Setu Bandha variation",duration:"Hold 3-5 minutes",benefits:"Passive backbend that opens chest and relieves Capricorn chronic back tension without any effort. Rest in the pose not work it.",steps:["Lie on your back with knees bent and feet flat on mat","Place a yoga block under your sacrum on medium or high height","Let hips rest fully on block with the body completely passive","Arms open out to sides with palms facing upward","Let chest open naturally without any effort from you","Breathe and rest here fully for 3-5 minutes"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#1a2a3a" rx="10"/><line x1="10" y1="128" x2="110" y2="128" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><rect x="44" y="110" width="24" height="12" rx="3" fill="rgba(255,255,255,.3)"/><ellipse cx="25" cy="129" rx="10" ry="4" fill="rgba(255,255,255,.45)"/><ellipse cx="90" cy="129" rx="10" ry="4" fill="rgba(255,255,255,.45)"/><line x1="25" y1="128" x2="38" y2="112" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="90" y1="128" x2="75" y2="112" stroke="white" stroke-width="6" stroke-linecap="round"/><path d="M38,112 Q56,100 56,110 Q56,110 75,112" fill="none" stroke="white" stroke-width="5" stroke-linecap="round"/><circle cx="18" cy="118" r="8" fill="white"/><circle cx="18" cy="118" r="5" fill="#1a2a3a"/></svg>'},
"Yin Yoga Spine Sequence":{sanskrit:"Yin practice",duration:"30-45 minutes total",benefits:"Long held spine poses release years of stored tension from Capricorn carrying so much weight. Deeply restorative and absolutely necessary.",steps:["Lay out 5-6 spine poses: Caterpillar, Sphinx, Dragon, Twisted Roots","Hold each pose 3-5 minutes without adjusting or moving","Use blankets and blocks generously for complete support","Focus on your breathing not on stretching deeper","Allow sensations to arise without forcing further","End with 10 minutes of Yoga Nidra for full integration"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0a1a2a" rx="10"/><line x1="10" y1="118" x2="110" y2="118" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><line x1="18" y1="115" x2="95" y2="115" stroke="white" stroke-width="7" stroke-linecap="round"/><ellipse cx="13" cy="115" rx="7" ry="4" fill="rgba(255,255,255,.4)"/><ellipse cx="99" cy="115" rx="7" ry="4" fill="rgba(255,255,255,.4)"/><circle cx="18" cy="112" r="9" fill="white"/><circle cx="18" cy="112" r="6" fill="#0a1a2a"/></svg>'},
"Inversion Practice":{sanskrit:"Various inversions",duration:"Work up to 1-3 minutes",benefits:"Feeds Aquarius love of unique perspectives - literally seeing the world upside down. Calms nervous system and builds mental focus.",steps:["Start with Legs Up the Wall for 5 minutes to begin","Progress to Supported Shoulderstand when ready","Try Headstand against a wall for support and safety","Keep neck long and breathe very steadily throughout","Inversions require gradual practice - build slowly over time","Always rest in Child Pose or Savasana after inversions"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0c2a4a" rx="10"/><line x1="20" y1="140" x2="100" y2="140" stroke="rgba(255,255,255,.3)" stroke-width="2"/><ellipse cx="60" cy="137" rx="14" ry="5" fill="rgba(255,255,255,.3)"/><line x1="55" y1="133" x2="55" y2="72" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="65" y1="133" x2="65" y2="72" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="72" x2="60" y2="40" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="55" y1="108" x2="30" y2="118" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="65" y1="108" x2="90" y2="118" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="60" cy="30" r="10" fill="white"/><circle cx="60" cy="30" r="7" fill="#0c2a4a"/></svg>'},
"Kundalini Yoga":{sanskrit:"Kundalini practice",duration:"30-60 minutes",benefits:"Aligns with Aquarius higher frequency energy. Works on the energetic body through kriyas mantras and breathwork for transformation.",steps:["Wear comfortable white clothing if you feel called to","Begin with tuning in mantra: Ong Namo Guru Dev Namo","Choose a kriya - a specific series of movements and breath","Use mantras throughout to focus the wandering Aquarius mind","End with deep relaxation and silent meditation","Practice consistently for 40 days to experience transformation"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0c1a4a" rx="10"/><line x1="10" y1="140" x2="110" y2="140" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="60" cy="141" rx="10" ry="3" fill="rgba(255,255,255,.4)"/><line x1="60" y1="140" x2="60" y2="108" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="108" x2="60" y2="75" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="120" x2="38" y2="128" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="120" x2="82" y2="128" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="92" x2="40" y2="80" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="92" x2="80" y2="80" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="60" cy="64" r="11" fill="white"/><circle cx="60" cy="64" r="7" fill="#0c1a4a"/><circle cx="60" cy="46" r="4" fill="rgba(100,200,255,.6)"/><circle cx="60" cy="38" r="3" fill="rgba(100,200,255,.4)"/></svg>'},
"Group Yoga":{sanskrit:"Sangha practice",duration:"60-90 minutes",benefits:"Aquarius thrives in collective healing spaces. The community energy in a group yoga class feeds this sign humanitarian spirit perfectly.",steps:["Find a local yoga studio or a community class near you","Arrive a few minutes early to connect with fellow students","Allow yourself to fully receive the teacher guidance and wisdom","Notice how the collective breath creates a shared healing field","After class take a moment to speak with one new person","Consider building a regular consistent community practice"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0c1a4a" rx="10"/><line x1="10" y1="130" x2="110" y2="130" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="25" cy="131" rx="8" ry="3" fill="rgba(255,255,255,.35)"/><ellipse cx="60" cy="131" rx="8" ry="3" fill="rgba(255,255,255,.35)"/><ellipse cx="95" cy="131" rx="8" ry="3" fill="rgba(255,255,255,.35)"/><line x1="25" y1="130" x2="25" y2="92" stroke="rgba(255,255,255,.6)" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="130" x2="60" y2="90" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="95" y1="130" x2="95" y2="92" stroke="rgba(255,255,255,.6)" stroke-width="4" stroke-linecap="round"/><line x1="25" y1="108" x2="14" y2="114" stroke="rgba(255,255,255,.6)" stroke-width="3"/><line x1="25" y1="108" x2="36" y2="114" stroke="rgba(255,255,255,.6)" stroke-width="3"/><line x1="60" y1="105" x2="48" y2="112" stroke="white" stroke-width="4"/><line x1="60" y1="105" x2="72" y2="112" stroke="white" stroke-width="4"/><circle cx="25" cy="81" r="9" fill="rgba(255,255,255,.6)"/><circle cx="60" cy="79" r="11" fill="white"/><circle cx="60" cy="79" r="7" fill="#0c1a4a"/><circle cx="95" cy="81" r="9" fill="rgba(255,255,255,.6)"/></svg>'},
"Breathwork Pranayama":{sanskrit:"Pranayama",duration:"10-20 minutes",benefits:"Aquarius air element benefits enormously from conscious breathing. Pranayama directly calms the nervous system and sharpens the visionary mind.",steps:["Sit comfortably with spine straight and tall","Begin with natural breath awareness for 2 minutes","Try Box Breathing: inhale 4 counts, hold 4, exhale 4, hold 4","Or practice 4-7-8: inhale 4, hold 7, exhale 8 slowly","Practice for 10-20 minutes every single day","End with a few minutes of natural breath and open stillness"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0c1a4a" rx="10"/><circle cx="60" cy="55" r="20" fill="none" stroke="rgba(100,200,255,.4)" stroke-width="2"/><circle cx="60" cy="55" r="14" fill="none" stroke="rgba(100,200,255,.3)" stroke-width="1.5"/><circle cx="60" cy="55" r="8" fill="rgba(100,200,255,.25)"/><line x1="10" y1="140" x2="110" y2="140" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="60" cy="141" rx="10" ry="3" fill="rgba(255,255,255,.4)"/><line x1="60" y1="140" x2="60" y2="108" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="108" x2="60" y2="80" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="120" x2="40" y2="128" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="120" x2="80" y2="128" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="95" x2="40" y2="84" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="95" x2="80" y2="84" stroke="white" stroke-width="4" stroke-linecap="round"/></svg>'},
"Fish Pose":{sanskrit:"Matsyasana",duration:"Hold 30-60 seconds",benefits:"Pisces very own pose. Opens the heart and throat completely. Releases held grief and reconnects Pisces to their deep oceanic nature.",steps:["Lie on your back with legs extended comfortably","Slide hands under buttocks with palms facing down","Press forearms and elbows firmly into the mat","Arch your back and lift chest up high toward the ceiling","Let the very top of head rest gently on mat","Breathe deeply into the wide open throat and heart"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0a1a4a" rx="10"/><line x1="10" y1="118" x2="110" y2="118" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><line x1="55" y1="115" x2="95" y2="115" stroke="white" stroke-width="6" stroke-linecap="round"/><ellipse cx="97" cy="115" rx="7" ry="3" fill="rgba(255,255,255,.4)"/><path d="M55,115 Q35,100 28,88 Q22,78 28,68" fill="none" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="40" y1="108" x2="18" y2="115" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="28" cy="62" r="9" fill="white"/><circle cx="28" cy="62" r="6" fill="#0a1a4a"/></svg>'},
"Restorative Yoga":{sanskrit:"Restorative practice",duration:"45-75 minutes",benefits:"The most deeply nourishing practice for Pisces sensitive nervous system. Full support in every pose allows the deepest possible healing rest.",steps:["Gather blankets bolsters blocks and an eye pillow","Choose 4-5 restorative poses: Supported Fish, Legs Up Wall, Child Pose","Set up each pose with complete support - zero effort required","Hold each pose 5-10 minutes with eye pillow covering eyes","Allow your body to completely and totally surrender","End with 15 minutes of Yoga Nidra for deepest integration"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0a0a2a" rx="10"/><rect x="25" y="100" width="70" height="18" rx="5" fill="rgba(255,255,255,.2)"/><line x1="10" y1="120" x2="110" y2="120" stroke="rgba(255,255,255,.2)" stroke-width="1.5"/><line x1="20" y1="107" x2="90" y2="107" stroke="white" stroke-width="7" stroke-linecap="round"/><ellipse cx="17" cy="107" rx="7" ry="4" fill="rgba(255,255,255,.4)"/><ellipse cx="93" cy="107" rx="7" ry="4" fill="rgba(255,255,255,.4)"/><circle cx="20" cy="105" r="9" fill="white"/><circle cx="20" cy="105" r="6" fill="#0a0a2a"/></svg>'},
"Supine Butterfly":{sanskrit:"Supta Baddha Konasana",duration:"5-10 minutes",benefits:"Opens the hips chest and heart simultaneously. Allows deep emotional release and is profoundly restorative for Pisces sensitive body.",steps:["Lie on your back in a comfortable position","Bring soles of feet together and let knees fall open wide","Place one hand on heart and the other on your belly","Close your eyes and breathe naturally without controlling","Place pillows or blankets under knees if needed for comfort","Stay 5-10 minutes allowing full surrender and release"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0a1a3a" rx="10"/><line x1="10" y1="118" x2="110" y2="118" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><line x1="20" y1="110" x2="75" y2="110" stroke="white" stroke-width="7" stroke-linecap="round"/><line x1="75" y1="110" x2="38" y2="118" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="75" y1="110" x2="95" y2="118" stroke="white" stroke-width="5" stroke-linecap="round"/><ellipse cx="36" cy="119" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><ellipse cx="97" cy="119" rx="9" ry="3" fill="rgba(255,255,255,.4)"/><line x1="42" y1="108" x2="36" y2="98" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="55" y1="108" x2="60" y2="98" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="36" cy="96" r="4" fill="white"/><circle cx="61" cy="96" r="4" fill="white"/><circle cx="20" cy="108" r="9" fill="white"/><circle cx="20" cy="108" r="6" fill="#0a1a3a"/></svg>'},
"Ocean Breath Ujjayi Pranayama":{sanskrit:"Ujjayi Pranayama",duration:"Throughout practice, 5-20 minutes",benefits:"The sound of the sea calms Pisces to their very core. This breath creates an oceanic sound that anchors the wandering Pisces mind.",steps:["Sit comfortably or use this breath throughout your yoga flow","Inhale through nose, slightly constrict the back of your throat","Create a soft gentle ocean wave sound on your exhale","Both inhale and exhale flow only through the nose","The sound should be audible only to yourself","Maintain this soothing breath throughout your entire practice"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0a1a4a" rx="10"/><path d="M10,75 Q25,60 40,75 Q55,90 70,75 Q85,60 100,75" fill="none" stroke="rgba(100,180,255,.5)" stroke-width="2"/><path d="M10,90 Q25,75 40,90 Q55,105 70,90 Q85,75 100,90" fill="none" stroke="rgba(100,180,255,.35)" stroke-width="1.5"/><line x1="10" y1="140" x2="110" y2="140" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><ellipse cx="60" cy="141" rx="10" ry="3" fill="rgba(255,255,255,.4)"/><line x1="60" y1="140" x2="60" y2="108" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="108" x2="60" y2="80" stroke="white" stroke-width="6" stroke-linecap="round"/><line x1="60" y1="120" x2="40" y2="128" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="120" x2="80" y2="128" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="60" y1="95" x2="42" y2="84" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="60" y1="95" x2="78" y2="84" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="60" cy="69" r="11" fill="white"/><circle cx="60" cy="69" r="7" fill="#0a1a4a"/></svg>'},"Seated Spinal Twist":{sanskrit:"Ardha Matsyendrasana",duration:"Hold 1 minute each side",benefits:"Supports Gemini lungs nervous system and digestive organs. The classic detox twist that releases mental tension from the spine.",steps:["Sit on the floor with legs extended straight","Bend right knee and place right foot outside left thigh","Inhale to lengthen spine and lift tall","Exhale and twist right, left elbow outside right knee","Right hand on floor behind you for support","Hold 1 minute breathing into the twist, then switch sides"],svg:'<svg viewBox="0 0 120 160" xmlns="http://www.w3.org/2000/svg"><rect width="120" height="160" fill="#0c2a3a" rx="10"/><line x1="15" y1="118" x2="105" y2="118" stroke="rgba(255,255,255,.3)" stroke-width="1.5"/><line x1="22" y1="115" x2="72" y2="115" stroke="white" stroke-width="7" stroke-linecap="round"/><ellipse cx="74" cy="115" rx="5" ry="3" fill="white"/><line x1="50" y1="115" x2="52" y2="92" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="52" y1="92" x2="62" y2="108" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="52" y1="92" x2="45" y2="75" stroke="white" stroke-width="5" stroke-linecap="round"/><line x1="48" y1="84" x2="28" y2="76" stroke="white" stroke-width="4" stroke-linecap="round"/><line x1="48" y1="82" x2="72" y2="68" stroke="white" stroke-width="4" stroke-linecap="round"/><circle cx="26" cy="75" r="4" fill="white"/><circle cx="74" cy="66" r="4" fill="white"/><circle cx="45" cy="64" r="9" fill="white"/><circle cx="45" cy="64" r="6" fill="#0c2a3a"/></svg>'}
};


var CDESC={"Rose Quartz":"The stone of unconditional love \u2014 opens the heart and attracts loving energy.","Carnelian":"Ignites courage, motivation, and fiery action when you need momentum.","Amethyst":"Powerful spiritual protection. Calms the mind and deepens intuition.","Malachite":"Stone of transformation \u2014 absorbs negative energy and accelerates change.","Citrine":"The merchant\u2019s stone \u2014 attracts abundance, joy, and sunny optimism.","Moonstone":"Deeply connected to lunar cycles \u2014 enhances intuition and feminine energy.","Labradorite":"Stone of magic \u2014 creates a shimmering shield and amplifies psychic gifts.","Black Onyx":"Provides strength and grounding. Absorbs and transforms negative energy.","Black Obsidian":"Volcanic glass that cuts through illusion and reveals deep truths.","Selenite":"Pure cleansing light \u2014 purifies energy and connects to higher consciousness.","Pyrite":"Fool\u2019s Gold of real abundance \u2014 builds confidence and willpower.","Tiger's Eye":"Balances grounded earth energy with solar fire. Sharpens focus and power.","Red Jasper":"Stone of endurance \u2014 grounds and stabilizes with earthy, nurturing energy.","White Quartz":"The master healer \u2014 amplifies all intentions and purifies energy.","Lapis Lazuli":"Stone of ancient wisdom \u2014 speaks truth and connects to royal inner knowing.","Red Agate":"Brings courage, strength, and harmony during challenging transitions.","Sodalite":"Deepens logic, intuition, and authentic self-expression.","Black Tourmaline":"The ultimate protective stone \u2014 creates an impenetrable energetic shield.","Fluorite":"The genius stone \u2014 organizes thought, enhances focus, and clarifies the mind.","Black Kyanite":"Instantly aligns all chakras and never needs energetic cleansing.","Bismuth":"The rainbow crystal \u2014 eases feelings of loneliness and supports transformation.","Aquamarine":"Sea energy crystal \u2014 brings calm, clear communication, and soothing courage."};
var CCOLOR={"Rose Quartz":"#f9a8d4","Carnelian":"#f97316","Amethyst":"#9b7cc8","Malachite":"#22c55e","Citrine":"#fbbf24","Moonstone":"#e8eeff","Labradorite":"#06b6d4","Black Onyx":"#374151","Black Obsidian":"#1f2937","Selenite":"#f9fafb","Pyrite":"#d97706","Tiger's Eye":"#92400e","Red Jasper":"#dc2626","White Quartz":"#f0f9ff","Lapis Lazuli":"#1e40af","Red Agate":"#ea580c","Sodalite":"#2563eb","Black Tourmaline":"#111827","Fluorite":"#818cf8","Black Kyanite":"#1e3a8a","Bismuth":"#ec4899","Aquamarine":"#38bdf8"};
var EMOJI={"Rose Quartz":"\ud83e\udea8","Carnelian":"\ud83d\udfe0","Amethyst":"\ud83d\udc9c","Malachite":"\ud83d\udfe2","Citrine":"\ud83c\udf1f","Moonstone":"\ud83c\udf19","Labradorite":"\u2728","Black Onyx":"\u26ab","Black Obsidian":"\u26ab","Selenite":"\ud83e\uddb3","Pyrite":"\u2b50","Tiger's Eye":"\ud83d\udc2f","Red Jasper":"\ud83d\udd34","White Quartz":"\ud83d\udca0","Lapis Lazuli":"\ud83d\udc99","Red Agate":"\ud83d\udd36","Sodalite":"\ud83d\udd37","Black Tourmaline":"\ud83d\udda4","Fluorite":"\ud83d\udd2e","Black Kyanite":"\ud83d\udca0","Bismuth":"\ud83c\udf08","Aquamarine":"\ud83d\udca0"};

function showFallback(container,name){
  var bg=CCOLOR[name]||'#c8c0e0';
  var em=EMOJI[name]||'\ud83d\udca0';
  container.innerHTML='<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:1.8rem;background:'+bg+'">'+em+'</div>';
}

function fillPhoto(container,name){
  var src=PHOTOS[name];
  if(src){
    var img=new Image();
    img.alt=name;
    img.style.cssText='width:100%;height:100%;object-fit:cover;display:block;';
    img.onload=function(){container.innerHTML='';container.appendChild(img);};
    img.onerror=function(){showFallback(container,name);};
    img.src=src;
  }else{
    showFallback(container,name);
  }
}

function showPage(name,btn){
  document.querySelectorAll('.nav-tab').forEach(function(t){t.classList.remove('on');});
  btn.classList.add('on');
  document.querySelectorAll('.page').forEach(function(p){p.classList.remove('on');});
  document.getElementById(name+'-page').classList.add('on');
  if(name==='healing'){
    var hc=document.getElementById('healing-content');
    if(!hc.children.length) buildHealingPage();
  }
}

function buildHealingPage(){
  var hc=document.getElementById('healing-content');
  hc.innerHTML=
    '<div class="healing-hero"><h2>&#129544; Crystal Healing &amp; Yoga</h2>'
    +'<p>Crystal placement &bull; Healing rituals &bull; Yoga poses &bull; Life balance</p></div>'
    +'<div class="sign-picker" id="sign-picker"></div>'
    +'<div class="healing-panel" id="healing-panel"></div>';
  var picker=document.getElementById('sign-picker');
  ZODIAC.forEach(function(z,i){
    var b=document.createElement('button');
    b.className='sign-pick-btn'+(i===0?' on':'');
    b.innerHTML=z.em+' '+z.n;
    b.onclick=function(){
      document.querySelectorAll('.sign-pick-btn').forEach(function(x){x.classList.remove('on');});
      b.classList.add('on');
      renderHealingSign(z);
    };
    picker.appendChild(b);
  });
  renderHealingSign(ZODIAC[0]);
}

function renderHealingSign(z){
  var panel=document.getElementById('healing-panel');
  var w=WELLNESS[z.n]||{};
  var cpills=z.cr.map(function(cn,i){
    return '<div class="crys-pill"><div class="crys-pill-img" id="hpi-'+i+'"></div>'
      +'<span class="crys-pill-name">'+cn+'</span></div>';
  }).join('');

  // Build rich yoga pose cards with illustrations
  var yitems='';
  (w.yoga||[]).forEach(function(p){
    var parts=p.split(' - ');
    var poseName=parts[0].trim();
    var poseDesc=parts[1]||'';
    var pose=YOGA_POSES[poseName];
    if(pose){
      yitems+='<div class="yoga-pose-card" onclick="togglePose(this)">'
        +'<div class="yoga-pose-header">'
        +'<div class="yoga-pose-art">'+pose.svg+'</div>'
        +'<div class="yoga-pose-meta">'
        +'<div class="yoga-pose-name">'+poseName+'</div>'
        +'<div class="yoga-pose-sanskrit">'+pose.sanskrit+'</div>'
        +'<div class="yoga-pose-duration">'+pose.duration+'</div>'
        +'<div class="yoga-pose-benefits">'+pose.benefits+'</div>'
        +'</div></div>'
        +'<div class="yoga-pose-steps">'
        +'<div class="yoga-steps-inner">'
        +'<div class="yoga-steps-title">How to do it</div>'
        +pose.steps.map(function(s,i){return '<div class="yoga-step"><div class="yoga-step-num">'+(i+1)+'</div><div>'+s+'</div></div>';}).join('')
        +'</div></div>'
        +'<div class="yoga-expand-hint">Tap to see step-by-step instructions</div>'
        +'</div>';
    } else {
      yitems+='<div class="yoga-item"><div class="yoga-card-pose">&#129528; '+poseName+'</div>'
        +(poseDesc?'<div class="yoga-item-desc">'+poseDesc+'</div>':'')+'</div>';
    }
  });

  panel.innerHTML=
    '<div class="healing-sign-hdr">'
    +'<div class="healing-sign-em">'+z.em+'</div>'
    +'<div><div class="healing-sign-name">'+z.n+' '+z.sym+'</div>'
    +'<div class="healing-sign-el">'+z.el+' sign &bull; '+z.dt+'</div></div>'
    +'</div>'
    +'<div class="h-card">'
    +'<div class="h-card-title" style="color:#d4a8e8"><span class="ico">&#128142;</span> Your Power Crystals</div>'
    +'<div class="crys-pills">'+cpills+'</div>'
    +'</div>'
    +'<div class="h-card">'
    +'<div class="h-card-title" style="color:#a8c8e8"><span class="ico">&#128205;</span> Where to Place Your Crystals</div>'
    +'<div class="h-text">'+(w.placement||'')+'</div>'
    +'</div>'
    +'<div class="h-card">'
    +'<div class="h-card-title" style="color:#c8a8e8"><span class="ico">&#10024;</span> Healing Practices &amp; Rituals</div>'
    +'<div class="h-text">'+(w.healing||'')+'</div>'
    +'</div>'
    +'<div class="h-card">'
    +'<div class="h-card-title" style="color:#a8e8c8"><span class="ico">&#9752;&#65039;</span> Life Balance for '+z.n+'</div>'
    +'<div class="h-text">'+(w.balance||'')+'</div>'
    +'</div>'
    +'<div class="body-diagram-wrap">'
    +'<div class="body-diagram-title"><span class="ico">&#129334;</span> Where to Place Your Crystals on Your Body</div>'
    +'<div class="body-diagram-subtitle">Lie down comfortably. Place each crystal on the chakra point shown. Close your eyes and breathe deeply for 10-20 minutes.</div>'
    +'<div class="body-diagram-svg-wrap">'+(BODY_DIAGRAMS[z.n]||'')+'</div>'
    +'<div class="body-diagram-steps">'
    +'<div class="body-step"><div class="body-step-num">1</div><div>Find a comfortable place to lie flat on your back on your mat or bed.</div></div>'
    +'<div class="body-step"><div class="body-step-num">2</div><div>Place each crystal on the chakra point shown in the diagram above.</div></div>'
    +'<div class="body-step"><div class="body-step-num">3</div><div>Set a timer for 10-20 minutes. Close your eyes and breathe slowly.</div></div>'
    +'<div class="body-step"><div class="body-step-num">4</div><div>Visualize each crystal glowing with its color, sending healing energy into that chakra.</div></div>'
    +'<div class="body-step"><div class="body-step-num">5</div><div>When the timer ends, take 3 deep breaths before slowly sitting up.</div></div>'
    +'</div>'
    +'</div>'
    +'<div class="h-card">'
    +'<div class="h-card-title" style="color:#b8d8f8"><span class="ico">&#129544;</span> Yoga Poses for Stress Relief</div>'
    +'<div style="font-size:.75rem;color:#7ab89a;margin-bottom:12px;font-style:italic;">Tap any pose to see step-by-step instructions</div>'
    +yitems
    +'</div>'
    +'<div class="h-affirmation">&#127807; '+(w.affirmation||z.af)+' &#127807;</div>';

  z.cr.forEach(function(cn,i){
    var el=document.getElementById('hpi-'+i);
    if(el)fillPhoto(el,cn);
  });
}

function togglePose(card){
  var isExp=card.classList.contains('expanded');
  // Collapse all others
  document.querySelectorAll('.yoga-pose-card').forEach(function(c){c.classList.remove('expanded');});
  if(!isExp){
    card.classList.add('expanded');
    var hint=card.querySelector('.yoga-expand-hint');
    if(hint)hint.textContent='Tap to close';
  }
}


function showPage(name,btn){
  document.querySelectorAll('.nav-tab').forEach(function(t){t.classList.remove('on');});
  btn.classList.add('on');
  document.querySelectorAll('.page').forEach(function(p){p.classList.remove('on');});
  document.getElementById(name+'-page').classList.add('on');
  if(name==='healing'){
    var hc=document.getElementById('healing-content');
    if(!hc.children.length) buildHealingPage();
  }
}

function buildHealingPage(){
  var hc=document.getElementById('healing-content');
  hc.innerHTML=
    '<div class="healing-hero"><h2>&#129544; Crystal Healing &amp; Yoga</h2>'
    +'<p>Crystal placement &bull; Healing rituals &bull; Yoga poses &bull; Life balance</p></div>'
    +'<div class="sign-picker" id="sign-picker"></div>'
    +'<div class="healing-panel" id="healing-panel"></div>';
  var picker=document.getElementById('sign-picker');
  ZODIAC.forEach(function(z,i){
    var b=document.createElement('button');
    b.className='sign-pick-btn'+(i===0?' on':'');
    b.innerHTML=z.em+' '+z.n;
    b.onclick=function(){
      document.querySelectorAll('.sign-pick-btn').forEach(function(x){x.classList.remove('on');});
      b.classList.add('on');
      renderHealingSign(z);
    };
    picker.appendChild(b);
  });
  renderHealingSign(ZODIAC[0]);
}

function renderHealingSign(z){
  var panel=document.getElementById('healing-panel');
  var w=WELLNESS[z.n]||{};
  var cpills=z.cr.map(function(cn,i){
    return '<div class="crys-pill"><div class="crys-pill-img" id="hpi-'+i+'"></div>'
      +'<span class="crys-pill-name">'+cn+'</span></div>';
  }).join('');
  var yitems='';
  (w.yoga||[]).forEach(function(p){
    var parts=p.split(' - ');
    yitems+='<div class="yoga-item"><div class="yoga-card-pose">&#129528; '+parts[0]+'</div>'
      +(parts[1]?'<div class="yoga-item-desc">'+parts[1]+'</div>':'')+'</div>';
  });
  panel.innerHTML=
    '<div class="healing-sign-hdr">'
    +'<div class="healing-sign-em">'+z.em+'</div>'
    +'<div><div class="healing-sign-name">'+z.n+' '+z.sym+'</div>'
    +'<div class="healing-sign-el">'+z.el+' sign &bull; '+z.dt+'</div></div>'
    +'</div>'
    +'<div class="h-card">'
    +'<div class="h-card-title" style="color:#d4a8e8"><span class="ico">&#128142;</span> Your Power Crystals</div>'
    +'<div class="crys-pills">'+cpills+'</div>'
    +'</div>'
    +'<div class="h-card">'
    +'<div class="h-card-title" style="color:#a8c8e8"><span class="ico">&#128205;</span> Where to Place Your Crystals</div>'
    +'<div class="h-text">'+(w.placement||'')+'</div>'
    +'</div>'
    +'<div class="h-card">'
    +'<div class="h-card-title" style="color:#c8a8e8"><span class="ico">&#10024;</span> Healing Practices &amp; Rituals</div>'
    +'<div class="h-text">'+(w.healing||'')+'</div>'
    +'</div>'
    +'<div class="h-card">'
    +'<div class="h-card-title" style="color:#a8e8c8"><span class="ico">&#9752;&#65039;</span> Life Balance for '+z.n+'</div>'
    +'<div class="h-text">'+(w.balance||'')+'</div>'
    +'</div>'
    +'<div class="h-card">'
    +'<div class="h-card-title" style="color:#b8d8f8"><span class="ico">&#129544;</span> Yoga for Stress Relief</div>'
    +yitems
    +'</div>'
    +'<div class="h-affirmation">&#127807; '+(w.affirmation||z.af)+' &#127807;</div>';
  z.cr.forEach(function(cn,i){
    var el=document.getElementById('hpi-'+i);
    if(el)fillPhoto(el,cn);
  });
}

function buildGrid(){
  var guide=document.getElementById('guide');
  ZODIAC.forEach(function(z){
    var card=document.createElement('div');
    card.className='zcard';
    var hdr=document.createElement('div');
    hdr.className='zsign-header el-'+z.el;
    hdr.style.color='white';
    hdr.innerHTML='<div style="font-size:1.5rem">'+z.em+'</div><div><div class="zsign-name">'+z.n+'</div><div class="zsign-dates">'+z.dt+'</div></div><div style="margin-left:auto;font-size:1.3rem;opacity:.6">'+z.sym+'</div>';
    card.appendChild(hdr);
    var row=document.createElement('div');
    row.className='crystal-row';
    z.cr.forEach(function(cn){
      var item=document.createElement('div');
      item.className='crystal-item';
      var ph=document.createElement('div');
      ph.className='crystal-photo';
      var nm=document.createElement('div');
      nm.className='crystal-name';
      nm.textContent=cn;
      item.appendChild(ph);
      item.appendChild(nm);
      row.appendChild(item);
      fillPhoto(ph,cn);
    });
    card.appendChild(row);
    var body=document.createElement('div');
    body.className='zcard-body';
    body.innerHTML='<div class="zcard-desc">'+z.ds+'</div><div class="zcard-traits">'+z.tr.map(function(t){return '<span class="ztrait">'+t+'</span>';}).join('')+'</div>';
    card.appendChild(body);
    card.addEventListener('click',function(){openModal(z);});
    guide.appendChild(card);
  });
}

var horoCache={};
var currentSign=null;

function getCrystalPower(n){
  var p={"Rose Quartz":"Love & Self-Worth","Carnelian":"Motivation & Courage","Amethyst":"Spiritual Protection","Malachite":"Transformation","Citrine":"Abundance & Joy","Moonstone":"Intuition & Cycles","Labradorite":"Magic & Protection","Black Onyx":"Strength & Grounding","Black Obsidian":"Truth & Shadow Work","Selenite":"Cleansing & Light","Pyrite":"Confidence & Wealth","Tiger's Eye":"Focus & Power","Red Jasper":"Endurance & Stability","White Quartz":"Clarity & Healing","Lapis Lazuli":"Wisdom & Truth","Red Agate":"Courage & Harmony","Sodalite":"Logic & Expression","Black Tourmaline":"Protection & Grounding","Fluorite":"Focus & Clarity","Black Kyanite":"Alignment & Balance","Bismuth":"Transformation & Unity","Aquamarine":"Calm & Communication"};
  return p[n]||"Healing & Balance";
}

function openModal(z){
  currentSign=z;
  var elC='el-'+z.el;
  var signMeanings=CRYSTAL_MEANINGS[z.n]||{};

  var mhtml=z.cr.map(function(cn,i){
    var meaning=signMeanings[cn]||CDESC[cn]||'';
    var power=getCrystalPower(cn);
    return '<div class="meaning-card">'
      +'<div class="meaning-photo" id="mcp-'+i+'"></div>'
      +'<div class="meaning-body">'
      +'<div class="meaning-name">'+cn+'</div>'
      +'<div class="meaning-power">'+power+'</div>'
      +'<div class="meaning-text">'+meaning+'</div>'
      +'</div></div>';
  }).join('');

  document.getElementById('modal').innerHTML=
    '<div class="modal-banner '+elC+'" style="color:white">'
    +'<button class="xbtn" onclick="closeModal()">&#x2715;</button>'
    +'<div style="font-size:2.5rem">'+z.em+'</div>'
    +'<div class="modal-title">'+z.n+' '+z.sym+'</div>'
    +'<div class="modal-dates">'+z.dt+' &bull; '+z.el+' sign</div>'
    +'</div>'
    +'<div class="modal-body">'
    +'<div class="mtabs">'
    +'<button class="mtab on" id="mt-m" onclick="stab(&quot;m&quot;)" style="white-space:nowrap">&#128142; Crystals</button>'
    +'<button class="mtab" id="mt-h" onclick="stab(&quot;h&quot;)" style="white-space:nowrap">&#128302; Horoscope</button>'
    +'<button class="mtab" id="mt-a" onclick="stab(&quot;a&quot;)" style="white-space:nowrap">&#11088; About</button>'
    +'</div>'
    +'<div class="mpanel on" id="mp-m">'
    +'<div class="meaning-intro">Your '+z.n+' crystals are uniquely matched to your energy. Each was chosen for a specific reason.</div>'
    +mhtml
    +'<div class="affbox" style="margin-top:14px">'+z.af+'</div>'
    +'</div>'
    +'<div class="mpanel" id="mp-h">'
    +'<div class="hload"><div class="spin"></div><div>Reading the stars...</div></div>'
    +'</div>'
    +'<div class="mpanel" id="mp-a">'
    +'<p style="font-size:.87rem;line-height:1.78;color:#3a2a10;margin-bottom:14px">'+z.ds+'</p>'
    +'<div class="zcard-traits" style="margin-bottom:14px">'+z.tr.map(function(t){return '<span class="ztrait">'+t+'</span>';}).join('')+'</div>'
    +'<div class="affbox">'+z.af+'</div>'
    +'</div>'
    +'</div>';

  document.getElementById('overlay').classList.add('on');
  document.body.style.overflow='hidden';
  z.cr.forEach(function(cn,i){
    var c=document.getElementById('mcp-'+i);
    if(c)fillPhoto(c,cn);
  });
  loadHoro(z);
}

function stab(t){
  ['m','h','a'].forEach(function(x){var m=document.getElementById('mt-'+x);var p=document.getElementById('mp-'+x);if(m)m.classList.remove('on');if(p)p.classList.remove('on');});
  var m=document.getElementById('mt-'+t);var p=document.getElementById('mp-'+t);
  if(m)m.classList.add('on');if(p)p.classList.add('on');
}

function closeModal(){document.getElementById('overlay').classList.remove('on');document.body.style.overflow='';}
function maybeClose(e){if(e.target===document.getElementById('overlay'))closeModal();}
document.addEventListener('keydown',function(e){if(e.key==='Escape')closeModal();});

function getGeminiKey(){return localStorage.getItem('gemini_api_key')||atob('QVEuQWI4Uk42S0JWcHVEMVFkN0FJTDRJMXVNSDVVdEttTXl3b18yVGN2SDc5c19VeWx3MXc=');}

function promptForKey(callback){
  var existing=getGeminiKey();
  if(existing){callback(existing);return;}
  var overlay=document.createElement('div');
  overlay.style.cssText='position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.85);z-index:9999;display:flex;align-items:center;justify-content:center;padding:20px;box-sizing:border-box';
  overlay.innerHTML='<div style="background:#1a0a3a;border:1.5px solid #7c5cbf;border-radius:18px;padding:28px 24px;max-width:400px;width:100%;text-align:center">'
    +'<div style="font-size:1.8rem;margin-bottom:10px">&#127775;</div>'
    +'<div style="font-family:Georgia,serif;font-size:1.2rem;color:#d4b8ff;margin-bottom:8px">Connect Your AI</div>'
    +'<div style="font-size:.82rem;color:#a090c0;line-height:1.65;margin-bottom:18px">This app uses Google Gemini AI (free!) for personalized horoscopes and tarot readings.<br><br>'
    +'<strong style="color:#c4a8ff">Get your free key in 2 minutes:</strong><br>'
    +'1. Go to <a href="https://aistudio.google.com/apikey" target="_blank" style="color:#7dd3fc">aistudio.google.com/apikey</a><br>'
    +'2. Sign in with your Google account<br>'
    +'3. Click "Create API Key"<br>'
    +'4. Paste it below</div>'
    +'<input id="gemini-key-input" type="password" placeholder="Paste your Gemini API key here" '
    +'style="width:100%;box-sizing:border-box;padding:10px 14px;border-radius:10px;border:1.5px solid #7c5cbf;background:#0d0520;color:white;font-size:.85rem;margin-bottom:12px;outline:none"/>'
    +'<button onclick="saveGeminiKey()" style="width:100%;padding:11px;border-radius:10px;background:linear-gradient(135deg,#7c5cbf,#4a2a8f);border:none;color:white;font-size:.9rem;font-weight:bold;cursor:pointer;margin-bottom:8px">&#9733; Activate Free AI Features</button>'
    +'<div style="font-size:.72rem;color:#7060a0">Your key is saved only in this browser. We never see it. If you switch browsers or clear your cache, check your email from Google — they send you your key so you can paste it in again.</div>'
    +'</div>';
  document.body.appendChild(overlay);
  window._geminiCallback=callback;
  window._geminiOverlay=overlay;
}

function saveGeminiKey(){
  var key=document.getElementById('gemini-key-input').value.trim();
  if(!key){alert('Please paste your API key first.');return;}
  localStorage.setItem('gemini_api_key',key);
  if(window._geminiOverlay)window._geminiOverlay.remove();
  if(window._geminiCallback)window._geminiCallback(key);
}

function callGemini(prompt, onSuccess, onError){
  var key=getGeminiKey();
  if(!key){promptForKey(function(k){callGeminiWithKey(k,prompt,onSuccess,onError);});return;}
  callGeminiWithKey(key,prompt,onSuccess,onError);
}

function callGeminiWithKey(key,prompt,onSuccess,onError){
  var url='https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key='+key;
  fetch(url,{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({
      contents:[{parts:[{text:prompt}]}],
      generationConfig:{temperature:0.9,maxOutputTokens:900}
    })
  })
  .then(function(r){
    if(r.status===400||r.status===403){
      localStorage.removeItem('gemini_api_key');
      promptForKey(function(k){callGeminiWithKey(k,prompt,onSuccess,onError);});
      return null;
    }
    return r.json();
  })
  .then(function(data){
    if(!data)return;
    var text=(((data.candidates||[])[0]||{}).content||{}).parts||[];
    var raw=text.map(function(p){return p.text||'';}).join('').trim().replace(/```json|```/g,'').trim();
    onSuccess(raw);
  })
  .catch(function(e){if(onError)onError(e);});
}

function loadHoro(z){
  if(horoCache[z.n]){var p=document.getElementById('mp-h');if(p)renderHoro(horoCache[z.n]);return;}
  var d=new Date().toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'});
  var prompt='Write a horoscope for '+z.n+' on '+d+'. Return ONLY valid JSON, no markdown: {"overview":"2-3 warm poetic sentences","love":"1 sentence","career":"1 sentence","wellness":"1 sentence","lucky_number":42,"lucky_color":"violet","lucky_crystal":"Amethyst","energy_score":7,"love_score":8,"career_score":6}';
  callGemini(prompt,
    function(raw){
      try{
        var h=JSON.parse(raw);
        horoCache[z.n]=h;
        var p=document.getElementById('mp-h');
        if(p)renderHoro(h);
      }catch(e){
        var p=document.getElementById('mp-h');
        if(p)p.innerHTML='<div class="herr">Stars are quiet now...<button class="retrybtn" onclick="retryHoro()">Try Again</button></div>';
      }
    },
    function(){
      var p=document.getElementById('mp-h');
      if(p)p.innerHTML='<div class="herr">Stars are quiet now...<button class="retrybtn" onclick="retryHoro()">Try Again</button></div>';
    }
  );
}
function retryHoro(){if(!currentSign)return;delete horoCache[currentSign.n];var p=document.getElementById('mp-h');if(p)p.innerHTML='<div class="hload"><div class="spin"></div><div>Reading the stars...</div></div>';loadHoro(currentSign);}
function bar(v,c){return '<div class="hsbar"><div class="hsfill" style="width:'+v*10+'%;background:'+c+'"></div></div>';}
function renderHoro(h){
  var p=document.getElementById('mp-h');if(!p)return;
  var d=new Date().toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'});
  p.innerHTML='<div class="hcard"><div class="hdate">\ud83c\udf19 '+d+'</div><div class="htext">'+h.overview+'</div></div>'
    +'<div class="hscores"><div class="hscore"><div class="hslbl">\u2728 Energy</div>'+bar(h.energy_score,'linear-gradient(90deg,#d8c6f0,#9b7cc8)')+'<div class="hsval">'+h.energy_score+'/10</div></div>'
    +'<div class="hscore"><div class="hslbl">\ud83d\udc95 Love</div>'+bar(h.love_score,'linear-gradient(90deg,#f7c5d0,#e8a0b0)')+'<div class="hsval">'+h.love_score+'/10</div></div>'
    +'<div class="hscore"><div class="hslbl">\ud83c\udf1f Career</div>'+bar(h.career_score,'linear-gradient(90deg,#fddbb4,#f59e0b)')+'<div class="hsval">'+h.career_score+'/10</div></div></div>'
    +'<div style="margin-top:11px"><div class="hinsight"><div class="hilbl">\ud83d\udc95 Love</div><div class="hitxt">'+h.love+'</div></div>'
    +'<div class="hinsight"><div class="hilbl">\ud83d\udcbc Career</div><div class="hitxt">'+h.career+'</div></div>'
    +'<div class="hinsight"><div class="hilbl">\ud83c\udf3f Wellness</div><div class="hitxt">'+h.wellness+'</div></div></div>'
    +'<div class="hlucky"><div class="lchip"><div class="lclbl">Lucky #</div><div class="lcval">'+h.lucky_number+'</div></div>'
    +'<div class="lchip"><div class="lclbl">Color</div><div class="lcval">'+h.lucky_color+'</div></div>'
    +'<div class="lchip"><div class="lclbl">\ud83d\udc8e Crystal</div><div class="lcval">'+h.lucky_crystal+'</div></div></div>';
}

